def extract_github_info(url):
    match = re.search(r'raw\.githubusercontent\.com/([^/]+)/([^/]+)/(?:refs/heads/)?([^/]+)/(.*)', url)
    if match:
        owner = match.group(1)
        repo = match.group(2)
        branch = match.group(3)
        path = match.group(4)
        return f"{owner}/{repo}", path, branch
    return None, None, None

def update_github_cookie_file(config, new_content):
    token = get_local_github_token(config)
    repo, path, branch = extract_github_info(COOKIE_URL)
    
    if not token or not repo or not path:
        ui_log("UPDATE", "Lỗi: Không thể trích xuất Repo/Path hoặc thiếu Token Github.")
        return False
        
    url = f"https://api.github.com/repos/{repo}/contents/{path}"
    headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github.v3+json"}
    
    try:
        r = requests.get(url, headers=headers)
        if r.status_code != 200:
            return False
        sha = r.json().get("sha")
        
        encoded = base64.b64encode(new_content.encode('utf-8')).decode('utf-8')
        data = {
            "message": "Auto-claim cookies by Lychkins Runner",
            "content": encoded,
            "sha": sha,
            "branch": branch
        }
        res = requests.put(url, headers=headers, json=data)
        if res.status_code in [200, 201]:
            ui_log("UPDATE", "Đã lưu Cookie mới thành công lên Github!")
            return True
        else:
            ui_log("UPDATE", f"Lỗi lưu Cookie Github: {res.status_code}")
            return False
    except Exception as e:
        ui_log("UPDATE", f"Lỗi API Github: {e}")
        return False

def manage_remote_cookies(config, accounts, android_id):
    needed_suffixes = [acc['suffix'] for acc in accounts]
    ui_log("UPDATE", f"Đang kiểm tra Cookie... (Cần {len(needed_suffixes)} slot)")
    
    if 'COOKIE_URL' not in globals() or not COOKIE_URL:
        ui_log("UPDATE", "Lỗi: COOKIE_URL chưa được thêm vào file config!")
        return {}
        
    try:
        token = get_local_github_token(config)
        repo, path, branch = extract_github_info(COOKIE_URL)
        
        if repo and path and token:
            api_url = f"https://api.github.com/repos/{repo}/contents/{path}?ref={branch}"
            headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github.v3.raw"}
            response = requests.get(api_url, headers=headers, timeout=20)
            if response.status_code != 200:
                ui_log("UPDATE", f"Lỗi HTTP Cookie API: {response.status_code}")
                return {}
            data = response.text.strip()
        else:
            req = urllib.request.Request(COOKIE_URL, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req, timeout=20) as response:
                if response.status != 200:
                    ui_log("UPDATE", f"Lỗi HTTP Cookie: {response.status}")
                    return {}
                data = response.read().decode('utf-8').strip()
                
        lines = data.splitlines()
        
        owned_cookies_dict = {}
        expired_cookies = []
        empty_cookies = []
        updated_lines = []
        changed = False
        now = datetime.now()
        now_str = now.strftime("%Y%m%d_%H%M%S")
        
        for raw_line in lines:
            raw_line = raw_line.strip()
            if not raw_line:
                updated_lines.append(raw_line)
                continue
            
            line = raw_line
            idx = line.find("_|WARNING:-DO-NOT-SHARE")
            if idx == -1:
                updated_lines.append(line)
                continue
            
            # BƯỚC 1: Giải mã hóa
            if len(line) >= idx + 174 and line[idx + 170 : idx + 174] == "neco":
                line = line[:idx + 170] + line[idx + 174:]
            
            # BƯỚC 2: Tách thông tin. Regex tìm claimer_id (AndroidID-Suffix)
            m = re.search(r':([^:]+):(\d{8}_\d{6})$', line)
            if m:
                claimer_id = m.group(1)
                timestamp_str = m.group(2)
                cookie_and_prefix = line[:m.start()]
            else:
                claimer_id = None
                timestamp_str = None
                cookie_and_prefix = line
            
            prefix = cookie_and_prefix[:cookie_and_prefix.find("_|WARNING:-DO-NOT-SHARE")]
            cookie_val = cookie_and_prefix[cookie_and_prefix.find("_|WARNING:-DO-NOT-SHARE"):]
            
            is_unclaimed = False
            
            if claimer_id and claimer_id.startswith(f"{android_id}-"):
                suffix_part = claimer_id[len(f"{android_id}-"):]
                if suffix_part in needed_suffixes and suffix_part not in owned_cookies_dict:
                    owned_cookies_dict[suffix_part] = cookie_val
                    needs_time_update = True
                    if timestamp_str:
                        try:
                            last_time = datetime.strptime(timestamp_str, "%Y%m%d_%H%M%S")
                            if (now - last_time).total_seconds() < 43200: # Dưới 12 tiếng
                                needs_time_update = False
                        except Exception: pass
                        
                    if needs_time_update:
                        new_line = f"{prefix}{cookie_val}:{android_id}-{suffix_part}:{now_str}"
                        updated_lines.append(new_line)
                        changed = True
                    else:
                        updated_lines.append(line) # Vẫn còn hạn, giữ nguyên
                else:
                    # Tab này đã bị xóa hoặc dư thừa -> Đẩy vào list Expired để nhường cho Tab khác xài
                    expired_cookies.append({'prefix': prefix, 'cookie_val': cookie_val, 'original_line': line})
                    
            elif claimer_id and claimer_id == android_id:
                # Tương thích ngược: Coi như Expired để xả Suffix mới đè lên
                expired_cookies.append({'prefix': prefix, 'cookie_val': cookie_val, 'original_line': line})
                
            elif claimer_id:
                # Thuộc về máy khác -> Check hạn 24h
                is_expired = True
                if timestamp_str:
                    try:
                        last_time = datetime.strptime(timestamp_str, "%Y%m%d_%H%M%S")
                        if (now - last_time).total_seconds() <= 86400:
                            is_expired = False
                    except Exception: pass
                    
                if is_expired:
                    expired_cookies.append({'prefix': prefix, 'cookie_val': cookie_val, 'original_line': line})
                else:
                    updated_lines.append(line)
            else:
                # Trắng hoàn toàn
                empty_cookies.append({'prefix': prefix, 'cookie_val': cookie_val, 'original_line': line})

        # BƯỚC 3: Cấp phát Cookie cho các Tab chưa có (Ưu tiên: >24h trước, Trống sau)
        missing_suffixes = [s for s in needed_suffixes if s not in owned_cookies_dict]
        
        if missing_suffixes:
            ui_log("UPDATE", f"Đang lấy Cookie thay thế cho {len(missing_suffixes)} Tab...")
            for suffix in missing_suffixes:
                item = None
                if expired_cookies:
                    item = expired_cookies.pop(0)
                elif empty_cookies:
                    item = empty_cookies.pop(0)

                if item:
                    new_line = f"{item['prefix']}{item['cookie_val']}:{android_id}-{suffix}:{now_str}"
                    updated_lines.append(new_line)
                    owned_cookies_dict[suffix] = item['cookie_val']
                    changed = True
                else:
                    ui_log("UPDATE", f"Cảnh báo: Kho cookie hết chỗ! Tab '{suffix}' bị bỏ qua.")
        
        if len(owned_cookies_dict) == len(needed_suffixes):
            ui_log("UPDATE", f"Tuyệt vời. Đã gắn đủ {len(needed_suffixes)} Cookie / {len(needed_suffixes)} Tab.")
            
        # Dọn dẹp trả lại nguyên bản cho các cookie còn ế / hoặc do máy nhả ra
        for item in expired_cookies + empty_cookies:
            clean_line = f"{item['prefix']}{item['cookie_val']}"
            updated_lines.append(clean_line)
            if item['original_line'] != clean_line:
                changed = True
        
        # BƯỚC 4: Push lên Github nếu có sự thay đổi
        if changed:
            final_lines_to_push = []
            for l in updated_lines:
                idx = l.find("_|WARNING:-DO-NOT-SHARE")
                if idx != -1 and len(l) >= idx + 170:
                    l = l[:idx + 170] + "neco" + l[idx + 170:]
                final_lines_to_push.append(l)
                
            new_file_content = "\n".join(final_lines_to_push)
            ui_log("UPDATE", "Đang đồng bộ Cookie lên Github...")
            update_github_cookie_file(config, new_file_content)

        return owned_cookies_dict

    except Exception as e:
        ui_log("UPDATE", f"Lỗi xử lý Cookie: {e}")
        return {}

def find_real_cookie_path(package_name):
    base_path = f"/data/data/{package_name}/app_webview"
    possible_paths = [
        f"{base_path}/Default/Cookies",
        f"{base_path}/Cookies"
    ]
    for path in possible_paths:
        check_cmd = f"[ -f '{path}' ] && echo 'YES' || echo 'NO'"
        out, _, _ = run_root_cmd_injector(check_cmd)
        if "YES" in out:
            return path
    return None

def get_local_cookie_injector(package_name):
    target_path = find_real_cookie_path(package_name)
    if not target_path:
        return None

    if not os.path.exists(TEMP_DIR): os.makedirs(TEMP_DIR)
    temp_check_path = os.path.join(TEMP_DIR, "Cookies_Check")

    run_root_cmd_injector(f"cp {target_path} {temp_check_path}")
    run_root_cmd_injector(f"chmod 777 {temp_check_path}")

    local_cookie_value = None
    try:
        conn = sqlite3.connect(temp_check_path)
        cursor = conn.cursor()
        cursor.execute("SELECT value FROM cookies WHERE name = '.ROBLOSECURITY'")
        result = cursor.fetchone()
        if result: local_cookie_value = result[0]
        conn.close()
    except Exception: pass
    
    if os.path.exists(temp_check_path): os.remove(temp_check_path)
    return local_cookie_value

def prepare_db_injector(cookie_value):
    db_path = os.path.join(TEMP_DIR, COOKIE_FILENAME)
    if not os.path.exists(db_path): 
        return False
    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='cookies';")
        if not cursor.fetchone():
            conn.close()
            return False

        host_key = ".roblox.com"
        name = ".ROBLOSECURITY"
        cursor.execute("DELETE FROM cookies WHERE host_key = ? AND name = ?", (host_key, name))
        
        now = int(time.time() * 1000000)
        expires = 99999999999999999
        query_full = """
        INSERT INTO cookies (creation_utc, host_key, name, value, path, expires_utc, is_secure, is_httponly, last_access_utc, has_expires, is_persistent, priority, samesite, source_scheme)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """
        query_fallback = """
        INSERT INTO cookies (creation_utc, host_key, name, value, path, expires_utc, is_secure, is_httponly, last_access_utc)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        """
        try:
            cursor.execute(query_full, (now, host_key, name, cookie_value, "/", expires, 1, 1, now, 1, 1, 1, 0, 1))
        except sqlite3.OperationalError:
            cursor.execute(query_fallback, (now, host_key, name, cookie_value, "/", expires, 1, 1, now))

        conn.commit()
        conn.close()
        return True
    except Exception as e:
        return False

def inject_cookie_process(package_name, cookie_value):
    check_pkg, _, _ = run_root_cmd_injector(f"pm path {package_name}")
    if not check_pkg:
        return False

    target_path = find_real_cookie_path(package_name)
    if not target_path:
        return False

    # Chỉ tắt đúng 1 App bị lỗi, các App clone khác vẫn treo game bình thường
    run_root_cmd_injector(f"am force-stop {package_name}")
    time.sleep(1)

    if os.path.exists(TEMP_DIR): shutil.rmtree(TEMP_DIR)
    os.makedirs(TEMP_DIR)

    cmd_cp_out = f"cp {target_path} {TEMP_DIR}/{COOKIE_FILENAME}"
    _, err, code = run_root_cmd_injector(cmd_cp_out)
    if code != 0: return False

    run_root_cmd_injector(f"chmod 777 {TEMP_DIR}/{COOKIE_FILENAME}")

    if not prepare_db_injector(cookie_value): return False

    cmd_cp_in = f"cp {TEMP_DIR}/{COOKIE_FILENAME} {target_path}"
    run_root_cmd_injector(cmd_cp_in)

    parent_dir = os.path.dirname(target_path)
    owner_raw, _, _ = run_root_cmd_injector(f"stat -c '%U:%G' {parent_dir}")
    owner = owner_raw.strip()
    if owner:
        run_root_cmd_injector(f"chown {owner} {target_path}")
        run_root_cmd_injector(f"chmod 600 {target_path}")
    
    if os.path.exists(TEMP_DIR): shutil.rmtree(TEMP_DIR)
    return True

def get_roblox_user_id(cookie):
    try:
        url = "https://users.roblox.com/v1/users/authenticated"
        cookies = {'.ROBLOSECURITY': cookie}
        response = requests.get(url, cookies=cookies, timeout=10)
        if response.status_code == 200:
            data = response.json()
            return str(data.get('id'))
    except Exception: pass
    return None

def update_local_config_file(suffix, user_id):
    lines = []
    if os.path.exists(LOCAL_CONFIG_FILE):
        try:
            with open(LOCAL_CONFIG_FILE, "r") as f:
                lines = f.readlines()
        except: pass
    
    new_entry = f"{suffix}:{user_id}\n"
    updated = False
    new_content = []
    for line in lines:
        if line.strip().startswith(f"{suffix}:"):
            new_content.append(new_entry)
            updated = True
        elif line.strip():
            new_content.append(line)
            
    if not updated: new_content.append(new_entry)
    try:
        with open(LOCAL_CONFIG_FILE, "w") as f: f.writelines(new_content)
    except Exception: pass

