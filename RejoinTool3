def scanner_loop():
    while True:
        config = fetch_and_load_config(CONFIG_URL)
        if config.get("ENABLE_SCAN", "ON").upper() == "ON":
            run_scanner(config)
            time.sleep(config.get("SCAN_INTERVAL_SECONDS", 300))
        else:
            time.sleep(30)

def launcher_loop(mode):
    while True:
        config = fetch_and_load_config(CONFIG_URL)
        launch_roblox_instances(config, mode)
        countdown(config.get("LAUNCH_INTERVAL_SECONDS", 300))

def reboot_loop():
    while True:
        config = fetch_and_load_config(CONFIG_URL)
        if config.get("REBOOT_ENABLED", "off").lower() == "on":
            mins = config.get("REBOOT_INTERVAL_MINUTES", 1200)
            time.sleep(mins * 60)
            set_log("Thực thi lệnh Auto Reboot từ Config...")
            try: subprocess.run(["su", "-c", "reboot"])
            except: pass
        time.sleep(3600)

