def get_android_id():
    out, _, _ = run_root_cmd_injector("settings get secure android_id")
    if out and len(out) > 5:
        return out.strip()
    return "UNKNOWN_DEVICE_ID"

def auto_detect_roblox_packages(base_pkg):
    """Tự động quét các bản Roblox clone đang cài trên máy."""
    out, _, _ = run_root_cmd_injector(f"pm list packages | grep {base_pkg}")
    accounts = []
    if out:
        for line in out.splitlines():
            pkg = line.replace("package:", "").strip()
            if pkg.startswith(base_pkg):
                suffix = pkg[len(base_pkg):]
                accounts.append({'suffix': suffix, 'id': None})
    
    # Sắp xếp để đảm bảo thứ tự luôn cố định (VD: "", "1", "2", "3", "A")
    accounts = sorted(accounts, key=lambda x: x['suffix'])
    return accounts

