def fetch_proxies_from_url(url):
    try:
        response = requests.get(url, timeout=15)
        if response.status_code == 200:
            return [item.strip() for item in response.text.splitlines() if item.strip()]
    except Exception as e:
        ui_log("UPDATE", f"Lỗi tải proxy: {e}")
    return []

def get_local_github_token(config):
    """Giải mã và lấy Github Token từ biến trong Config."""
    token_str = config.get("OBFUSCATED_GITHUB_TOKEN", "")
    if token_str and token_str.startswith("neco") and token_str.endswith("neco"):
        core_token = token_str[4:-4]
        return f"ghp_{core_token}"
    return None

