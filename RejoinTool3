def get_cpu():
    global PREV_TOTAL, PREV_ACTIVE, CPU_PCT
    try:
        with open('/proc/stat', 'r') as f:
            line = f.readline()
        parts = line.split()
        if not parts or parts[0] != 'cpu': return
        user, nice, system, idle, iowait, irq, softirq = map(int, parts[1:8])
        total = user + nice + system + idle + iowait + irq + softirq
        active = total - idle - iowait
        if PREV_TOTAL > 0:
            diff_total = total - PREV_TOTAL
            diff_active = active - PREV_ACTIVE
            if diff_total > 0:
                CPU_PCT = str(int(diff_active * 100 / diff_total))
        PREV_TOTAL = total
        PREV_ACTIVE = active
    except: pass

def get_ram():
    global RAM_PCT
    try:
        mem_total = 0
        mem_avail = 0
        with open('/proc/meminfo', 'r') as f:
            for line in f:
                if line.startswith('MemTotal:'): mem_total = int(line.split()[1])
                elif line.startswith('MemAvailable:'): mem_avail = int(line.split()[1])
        if mem_total > 0 and mem_avail > 0:
            RAM_PCT = str(int(100 - (mem_avail * 100 / mem_total)))
    except: pass

