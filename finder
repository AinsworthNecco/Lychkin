-- ==========================================
-- TÌM KIẾM CÓ CHỐNG KẸT, ANTI-GACHA VÀ BLACKLIST
-- ==========================================
local TargetFails = {}
local BlacklistedTargets = {}

local function FindFruitTarget()
    for _, obj in pairs(workspace:GetDescendants()) do 
        if obj:IsA("Tool") and string.find(string.lower(obj.Name), "fruit") then
            if obj.Parent and obj.Parent:FindFirstChild("Humanoid") then continue end
            if obj.Parent and obj.Parent:IsA("Backpack") then continue end
            if BlacklistedTargets[obj] then continue end -- Bỏ qua nếu bị đưa vào danh sách đen
            
            if obj:FindFirstChild("Handle") then 
                return obj.Handle.CFrame, obj.Name, obj
            end
        end
        
        if obj:IsA("Model") and string.find(string.lower(obj.Name), "fruit") then
            if obj:FindFirstChildWhichIsA("Humanoid") then continue end
            local lowerName = string.lower(obj.Name)
            if string.find(lowerName, "gacha") or string.find(lowerName, "dealer") then continue end
            if obj.Name == "Fruit (Tự nhiên)" then continue end
            if BlacklistedTargets[obj] then continue end -- Bỏ qua nếu bị đưa vào danh sách đen

            if obj.PrimaryPart then
                return obj.PrimaryPart.CFrame, "Fruit (Tự nhiên)", obj
            else
                local fallbackPart = obj:FindFirstChildWhichIsA("BasePart")
                if fallbackPart then return fallbackPart.CFrame, "Fruit (Tự nhiên)", obj end
            end
        end
    end
    return nil, nil, nil
end

-- ==========================================
-- ĐỌC TÊN THẬT VÀ CHỐNG KẸT ĐẦY KHO
-- ==========================================
local function CheckAndStoreFruits()
    local storedFruitNames = {}
    local failedFruitNames = {}
    
    local function processItem(item)
        if item:IsA("Tool") and (string.find(string.lower(item.Name), "fruit") or item:GetAttribute("OriginalName")) then
            local realName = item:GetAttribute("OriginalName") or item.Name
            
            if Config.AutoStore then
                pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit", realName, item) end)
                task.wait(Config.WaitStore)
                
                if item and item.Parent then
                    table.insert(failedFruitNames, realName)
                    pcall(function() item:Destroy() end)
                else
                    table.insert(storedFruitNames, realName)
                end
            else
                table.insert(storedFruitNames, realName)
            end
        end
    end

    for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do processItem(item) end
    if LocalPlayer.Character then
        for _, item in pairs(LocalPlayer.Character:GetChildren()) do processItem(item) end
    end
    
    local storedStr = #storedFruitNames > 0 and table.concat(storedFruitNames, ", ") or nil
    local failedStr = #failedFruitNames > 0 and table.concat(failedFruitNames, ", ") or nil
    
    return storedStr, failedStr
end

-- ==========================================
-- WEBHOOK DISCORD (Đã fix chặn bằng webhook proxy hooks.hyra.io)
-- ==========================================
local function SendWebhook(realFruitName)
    if not Config.EnableWebhook or Config.WebhookURL == "" then return end

    -- Fix: Dùng hooks.hyra.io (rất ổn định) thay thế cho discord.com
    local SafeWebhookURL = string.gsub(Config.WebhookURL, "discord.com", "hooks.hyra.io")

    local data = {
        ["embeds"] = {{
            ["title"] = "🍏 Lượm Trái Thành Công!",
            ["description"] = "Tài khoản **" .. LocalPlayer.Name .. "** vừa nhặt được: **" .. realFruitName .. "**",
            ["color"] = tonumber(0x55FF55),
            ["timestamp"] = DateTime.now():ToIsoDate()
        }}
    }
    local jsonData = HttpService:JSONEncode(data)
    
    if httprequest then
        task.spawn(function()
            local success, result = pcall(function() 
                local response = httprequest({
                    Url = SafeWebhookURL, 
                    Method = "POST", 
                    Headers = { ["Content-Type"] = "application/json" }, 
                    Body = jsonData
                })
                return response
            end)
            
            -- Debugging Webhook
            if success and result and (result.StatusCode == 204 or result.StatusCode == 200) then
                UpdateStatus("🌐 Đã gửi thông báo Discord!", Color3.fromRGB(0, 150, 255))
            else
                UpdateStatus("⚠️ Lỗi Webhook (Xem F9)", Color3.fromRGB(220, 100, 0))
                warn("Lỗi gửi Webhook Discord: ", tostring(result and result.Body or result or "Không xác định"))
            end
        end)
    else
        UpdateStatus("⚠️ Executor không hỗ trợ Webhook", Color3.fromRGB(220, 100, 0))
    end
end

-- ==========================================
-- VÒNG LẶP CHÍNH CỦA AUTO
-- ==========================================
local function StartAutoLoop()
    UpdateStatus("✅ Khởi động Auto Fruit Neco Arc.", Color3.fromRGB(0, 150, 0))
    task.spawn(function()
        while Config.IsRunning do
            UpdateStatus("📡 Đang quét server tìm Fruit...", Color3.fromRGB(100, 100, 100))
            
            local targetCFrame, targetName, targetInstance = FindFruitTarget()
            
            if targetCFrame then
                UpdateStatus("🎯 Phát hiện mục tiêu: " .. targetName, Color3.fromRGB(0, 100, 200))
                
                TeleportTo(targetCFrame + Vector3.new(0, Config.SafeHeight, 0))
                task.wait(0.2)
                TeleportTo(targetCFrame)
                
                UpdateStatus("📦 Đang tiến hành nhặt trái...", Color3.fromRGB(180, 100, 0))
                task.wait(Config.WaitPickUp)
                
                local storedName, failedName = CheckAndStoreFruits()
                
                if storedName then
                    SendWebhook(storedName)
                    UpdateStatus("✨ Đã cất thành công: " .. storedName, Color3.fromRGB(0, 150, 0))
                    if targetInstance then TargetFails[targetInstance] = nil end -- Xóa lỗi nếu thành công
                elseif failedName then
                    UpdateStatus("⚠️ Kho đầy, skip trái: " .. failedName, Color3.fromRGB(200, 100, 0))
                    if targetInstance then TargetFails[targetInstance] = nil end -- Không tính là nhặt xịt vì đã nhặt được nhưng đầy kho
                else
                    UpdateStatus("❌ Nhặt xịt hoặc trái bị lỗi.", Color3.fromRGB(200, 50, 50))
                    
                    -- Cơ chế Fail-Safe (Nhặt xịt 3 lần thì đưa vào danh sách đen)
                    if targetInstance then
                        TargetFails[targetInstance] = (TargetFails[targetInstance] or 0) + 1
                        if TargetFails[targetInstance] >= 3 then
                            BlacklistedTargets[targetInstance] = true
                            UpdateStatus("🚫 Bỏ qua trái này do nhặt xịt 3 lần!", Color3.fromRGB(220, 0, 0))
                        else
                            UpdateStatus("🔄 Đang thử lại (Lỗi " .. TargetFails[targetInstance] .. "/3)...", Color3.fromRGB(200, 100, 0))
                        end
                    end
                end
                
                task.wait(Config.WaitScan)
            else
                UpdateStatus("⌛ Không có trái ác quỷ trên bản đồ.", Color3.fromRGB(150, 150, 150))
                task.wait(Config.WaitScan)
                if Config.IsRunning then 
                    UpdateStatus("🌐 Chuẩn bị đổi server...", Color3.fromRGB(120, 0, 180))
                    HopServer() 
                end
            end
        end
    end)
end

