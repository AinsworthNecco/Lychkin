local function SaveServerHistory()
    pcall(function()
        local count = 0
        for _ in pairs(ServerHistory) do count = count + 1 end
        if count >= Config.MaxServerHistory then
            ServerHistory = {} -- Xóa sạch khi đạt giới hạn
            UpdateStatus("🧹 Đã dọn dẹp bộ nhớ server history.", Color3.fromRGB(150, 150, 150))
        end
        writefile(ServerHistoryFile, HttpService:JSONEncode(ServerHistory))
    end)
end
