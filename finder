-- ==========================================
-- HÀM SERVER HOP SIÊU TỐC (RANDOM - ASCENDING)
-- ==========================================
local function HopServer()
    UpdateStatus("🔍 Đang tìm Server mới (Ít người)...", Color3.fromRGB(180, 100, 0))
    ServerHistory[game.JobId] = true
    SaveServerHistory()
    
    pcall(function()
        -- Sử dụng Asc để lấy server ít người chơi
        local ApiUrl = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Asc&limit=100&excludeFullGames=true"
        local RawData = game:HttpGet(ApiUrl)
        local Decoded = HttpService:JSONDecode(RawData)
        
        if Decoded and Decoded.data then
            local validServers = {}
            
            for _, server in ipairs(Decoded.data) do
                if server.id ~= game.JobId and server.playing < server.maxPlayers and not ServerHistory[server.id] then
                    table.insert(validServers, server)
                end
            end
            
            if #validServers > 0 then
                local randomServer = validServers[math.random(1, #validServers)]
                UpdateStatus("⚡ Tìm thấy server! Chuẩn bị kết nối...", Color3.fromRGB(0, 150, 0))
                
                ServerHistory[randomServer.id] = true
                SaveServerHistory()
                
                task.wait(Config.WaitHop)
                UpdateStatus("🚀 Đang Teleport...", Color3.fromRGB(0, 100, 200))
                TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer.id, LocalPlayer)
                return
            else
                UpdateStatus("⚠️ Không tìm thấy server hợp lệ. Dọn lịch sử...", Color3.fromRGB(200, 50, 50))
                ServerHistory = {}
                SaveServerHistory()
                task.wait(2)
            end
        end
    end)
    
    task.wait(3)
end

