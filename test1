#!/system/bin/sh

# Kiểm tra quyền root
if [ "$(id -u)" -ne 0 ]; then
    echo "Vui lòng chạy bằng su (root)"
    exit 1
fi

SWAPFILE="/data/local/swapfile"
SIZE="4G"

echo "Tạo swap $SIZE..."

# Tạo file swap
dd if=/dev/zero of=$SWAPFILE bs=1M count=4096

# Phân quyền
chmod 600 $SWAPFILE

# Tạo vùng swap
mkswap $SWAPFILE

# Kích hoạt swap
swapon $SWAPFILE

echo "Hoàn tất!"
free -h
