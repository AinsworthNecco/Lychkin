#!/system/bin/sh

# Nếu chưa root thì chạy lại toàn bộ script bằng su
if [ "$(id -u)" -ne 0 ]; then
    echo "Đang yêu cầu quyền root..."
    su -c sh << 'EOF'
$(cat)
EOF
    exit 0
fi

SWAPFILE="/data/local/swapfile"
SIZE="4G"

echo "Tạo swap $SIZE..."

dd if=/dev/zero of=$SWAPFILE bs=1M count=4096
chmod 600 $SWAPFILE
mkswap $SWAPFILE
swapon $SWAPFILE

echo "Hoàn tất!"
free -h
