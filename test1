#!/system/bin/sh

# Nếu chưa phải root thì tự gọi su để chạy lại script
if [ "$(id -u)" -ne 0 ]; then
    echo "Đang yêu cầu quyền root..."
    exec su -c "$0"
    exit 1
fi

SWAPFILE="/data/local/swapfile"
SIZE="4G"

echo "Tạo swap $SIZE..."

# Tạo file swap (4GB = 4096MB)
dd if=/dev/zero of=$SWAPFILE bs=1M count=4096

# Phân quyền
chmod 600 $SWAPFILE

# Tạo vùng swap
mkswap $SWAPFILE

# Kích hoạt swap
swapon $SWAPFILE

echo "Hoàn tất!"
free -h
