#!/system/bin/sh

SWAPFILE="/data/local/swapfile"
SIZE_MB=12288   # 12GB

echo "=== FARM MODE ENABLE ==="

# Nếu chưa root thì dừng
if [ "$(id -u)" -ne 0 ]; then
    echo "Cần quyền root!"
    exit 1
fi

# Tắt zram nếu có
if [ -e /dev/block/zram0 ]; then
    echo "Tắt zram..."
    swapoff /dev/block/zram0 2>/dev/null
    echo 1 > /sys/block/zram0/reset 2>/dev/null
fi

# Nếu swapfile chưa tồn tại thì tạo
if [ ! -f "$SWAPFILE" ]; then
    echo "Tạo swap ${SIZE_MB}MB..."
    dd if=/dev/zero of=$SWAPFILE bs=1M count=$SIZE_MB
    chmod 600 $SWAPFILE
    mkswap $SWAPFILE
fi

# Bật swap
swapon $SWAPFILE

# Tối ưu kernel
echo 100 > /proc/sys/vm/swappiness
echo 10 > /proc/sys/vm/vfs_cache_pressure
echo 0 > /proc/sys/vm/overcommit_memory

echo "Clear cache..."
sync
echo 3 > /proc/sys/vm/drop_caches

echo "=== FARM MODE ACTIVE ==="
free -h
