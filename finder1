local function TeleportTo(targetCFrame)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    char.HumanoidRootPart.CFrame = targetCFrame
end

-- ==========================================
-- TÌM KIẾM CỐT LÕI (GIỐNG BẢN GỐC ỔN ĐỊNH)
-- ==========================================
local function FindFruitTarget()
    for _, obj in pairs(workspace:GetDescendants()) do 
        -- 1. Tìm Tool rơi trên đất
        if obj:IsA("Tool") and string.find(string.lower(obj.Name), "fruit") then
            -- Chống kẹt: bỏ qua nếu nằm trong balo hoặc được cầm bởi người khác
            if obj.Parent and (obj.Parent:IsA("Backpack") or obj.Parent:FindFirstChild("Humanoid")) then continue end
            if obj:FindFirstChild("Handle") then 
                return obj.Handle.CFrame, obj.Name 
            end
        end
        
        -- 2. Tìm Model tự sinh ra
        if obj:IsA("Model") and string.find(string.lower(obj.Name), "fruit") then
            if obj.Name == "Fruit (Tự nhiên)" then continue end -- Bỏ qua rác
            if obj:FindFirstChildWhichIsA("Humanoid") then continue end -- Chống NPC

            if obj.PrimaryPart then
                return obj.PrimaryPart.CFrame, "Fruit (Tự nhiên)"
            else
                local fallbackPart = obj:FindFirstChildWhichIsA("BasePart")
                if fallbackPart then return fallbackPart.CFrame, "Fruit (Tự nhiên)" end
            end
        end
    end
    return nil, nil
end

-- ==========================================
-- ĐỌC TÊN THẬT VÀ CẤT KHO (CHỐNG ĐẦY)
-- ==========================================
local function CheckAndStoreFruits()
    local storedFruitNames = {}
    local failedFruitNames = {}
    
    local function processItem(item)
        if item:IsA("Tool") and (string.find(string.lower(item.Name), "fruit") or item:GetAttribute("OriginalName")) then
            local realName = item:GetAttribute("OriginalName") or item.Name
            
            if Config.AutoStore then
                pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit", realName, item) end)
                task.wait(0.5)
                
                -- Nếu kho đầy, đồ vẫn còn trong túi -> Xóa để chống kẹt
                if item and item.Parent then
                    table.insert(failedFruitNames, realName)
                    pcall(function() item:Destroy() end)
                else
                    table.insert(storedFruitNames, realName)
                end
            end
        end
    end

    for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do processItem(item) end
    if LocalPlayer.Character then
        for _, item in pairs(LocalPlayer.Character:GetChildren()) do processItem(item) end
    end
    
    local storedStr = #storedFruitNames > 0 and table.concat(storedFruitNames, ", ") or nil
    local failedStr = #failedFruitNames > 0 and table.concat(failedFruitNames, ", ") or nil
    return storedStr, failedStr
end

-- ==========================================
-- WEBHOOK DISCORD (CẬP NHẬT LOGIC MỚI)
-- ==========================================
local function SendWebhook(realFruitName)
    if not Config.EnableWebhook or Config.WebhookURL == "" then return end

    -- Proxy siêu ổn định
    local SafeWebhookURL = string.gsub(Config.WebhookURL, "discord.com", "webhook.lewisakura.moe")

    -- Format JSON đơn giản, loại bỏ các hàm dễ gây lỗi trên Executor
    local data = {
        content = "",
        embeds = {{
            title = "🍏 Lượm Trái Thành Công!",
            description = "Tài khoản **" .. LocalPlayer.Name .. "** vừa nhặt được: **" .. realFruitName .. "**",
            color = 5635925 -- Mã màu xanh lá (Decimal của 0x55FF55)
        }}
    }
    
    if httprequest then
        task.spawn(function()
            pcall(function() 
                httprequest({
                    Url = SafeWebhookURL, 
                    Method = "POST", 
                    Headers = { ["Content-Type"] = "application/json" }, 
                    Body = HttpService:JSONEncode(data)
                }) 
            end)
        end)
    end
end

-- ==========================================
-- VÒNG LẶP CHÍNH CỦA AUTO
-- ==========================================
local function StartAutoLoop()
    UpdateStatus("✅ Khởi động Auto Fruit Neco Arc.", Color3.fromRGB(0, 150, 0))
    task.spawn(function()
        while Config.IsRunning do
            UpdateStatus("📡 Đang quét server tìm Fruit...", Color3.fromRGB(100, 100, 100))
            
            local targetCFrame, targetName = FindFruitTarget()
            
            if targetCFrame then
                UpdateStatus("🎯 Phát hiện mục tiêu hợp lệ!", Color3.fromRGB(0, 100, 200))
                
                TeleportTo(targetCFrame + Vector3.new(0, Config.SafeHeight, 0))
                task.wait(0.2)
                TeleportTo(targetCFrame)
                
                UpdateStatus("📦 Đang tiến hành nhặt trái...", Color3.fromRGB(180, 100, 0))
                task.wait(1.5)
                
                local storedName, failedName = CheckAndStoreFruits()
                
                if storedName then
                    SendWebhook(storedName)
                    UpdateStatus("✨ Đã cất thành công: " .. storedName, Color3.fromRGB(0, 150, 0))
                elseif failedName then
                    UpdateStatus("⚠️ Kho đầy, skip trái: " .. failedName, Color3.fromRGB(200, 100, 0))
                else
                    UpdateStatus("❌ Nhặt xịt hoặc không phải trái.", Color3.fromRGB(200, 50, 50))
                end
                task.wait(1.5)
            else
                UpdateStatus("⌛ Không tìm thấy trái nào. Chuẩn bị Hop...", Color3.fromRGB(150, 150, 150))
                task.wait(1.5)
                if Config.IsRunning then HopServer() end
            end
        end
    end)
end

