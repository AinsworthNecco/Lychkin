def check_tty():
    """Kiểm tra xem script có đang chạy trong môi trường cho phép nhập liệu hay không"""
    if not sys.stdin.isatty():
        print("⚠️ CẢNH BÁO: Bạn đang chạy script trong môi trường KHÔNG TƯƠNG TÁC.")
        print("👉 Lỗi EOF có thể xảy ra. Vui lòng mở trực tiếp app Termux và gõ: python ten_file.py")
        print("-" * 50)

def safe_input(prompt_text):
    """Hàm nhập liệu an toàn, chống crash (văng) trên Termux khi bị EOF"""
    try:
        return input(prompt_text).strip()
    except EOFError:
        print("\n[!] Lỗi EOF: Không thể nhận dữ liệu nhập vào lúc này.")
        return ""
    except KeyboardInterrupt:
        print("\n[!] Bạn đã hủy nhập.")
        sys.exit()

def get_remaining_time(timestamp_ms):
    try:
        if not timestamp_ms:
            return "Không xác định"
        
        # Timestamp api là milliseconds, cần chia 1000 để ra seconds
        expire_dt = datetime.fromtimestamp(timestamp_ms / 1000)
        now = datetime.now()
        
        if expire_dt < now:
            return "Đã hết hạn"
        
        delta = expire_dt - now
        days = delta.days
        seconds = delta.seconds
        hours = seconds // 3600
        minutes = (seconds % 3600) // 60
        
        if days == 0 and hours == 0 and minutes == 0:
            return "Sắp hết hạn (dưới 1 phút)"
            
        return f"{days} ngày {hours} giờ {minutes} phút"
    except:
        return "Lỗi hiển thị"

def select_device(headers):
    print("\n[Đang tải danh sách thiết bị...]")
    url = "https://api.vsphone.com/vsphone/api/userEquipment/list?supplierType=-1&queryAuthorizedEquipments=true"
    
    try:
        response = requests.get(url, headers=headers, timeout=15)
        if response.status_code != 200:
            print(f"Lỗi tải danh sách (HTTP {response.status_code}).")
            return None
        
        data_json = response.json()
        if data_json.get("code") != 200:
            print(f"API Error: {data_json.get('msg')}")
            return None
        
        # Parse danh sách máy
        groups = data_json.get("data", [])
        all_pads = []
        
        for group in groups:
            pads = group.get("userPads", [])
            for pad in pads:
                all_pads.append(pad)
        
        if not all_pads:
            print("Không tìm thấy thiết bị nào trong tài khoản.")
            return None

        print("\n--- DANH SÁCH THIẾT BỊ ---")
        for idx, pad in enumerate(all_pads, 1):
            pad_name = pad.get("padName", "No Name")
            config_name = pad.get("configName", "No Config")
            expire_time = pad.get("signExpirationTimeTamp")
            equip_id = pad.get("equipmentId")
            
            remaining_str = get_remaining_time(expire_time)
            
            print(f"{idx}. [{pad_name}] - {config_name}")
            print(f"   ID: {equip_id} | Còn lại: {remaining_str}")
            print("-" * 30)
            
        # Cho người dùng chọn (Sử dụng hàm nhập an toàn)
        while True:
            choice = safe_input(f"Chọn máy cần gia hạn (1-{len(all_pads)}): ")
            if not choice: # Nếu bị lỗi EOF, trả về None để nhập thủ công
                return None

            if choice.isdigit():
                idx_choice = int(choice)
                if 1 <= idx_choice <= len(all_pads):
                    selected_pad = all_pads[idx_choice - 1]
                    print(f"\n=> Bạn đã chọn: {selected_pad.get('padName')} (ID: {selected_pad.get('equipmentId')})")
                    return str(selected_pad.get("equipmentId"))
            print("Lựa chọn không hợp lệ. Vui lòng chọn lại.")
            
    except Exception as e:
        print(f"Lỗi hệ thống khi lấy danh sách: {str(e)}")
        return None

def exchange_code():
    check_tty()
    print("--- TOOL AUTO ĐỔI CODE VSPHONE ---")
    
    user_token = CONFIG_TOKEN
    
    # Nếu chưa config token cứng thì hỏi nhập
    if not user_token:
        print("Cảnh báo: Chưa có Token trong cấu hình.")
        user_token = safe_input("Nhập Token để quét thiết bị: ")
        if not user_token:
            print("Lỗi: Không lấy được Token.")
            return
    
    # Cấu hình Headers
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Content-Type': 'application/json',
        'Accept': 'application/json, text/plain, */*',
        'Origin': 'https://www.vsphone.com',
        'Referer': 'https://www.vsphone.com/'
    }
    
    headers['token'] = user_token

    # 1. Chọn máy từ danh sách
    renew_id = select_device(headers)
    
    # Nếu không lấy được ID từ list (lỗi token, mạng, hoặc EOF trên Termux), cho nhập tay
    if not renew_id:
        print("\nChuyển sang chế độ nhập ID thủ công.")
        renew_id = safe_input("Nhập ID thiết bị (renewEquipmentIds): ")
    
    if not renew_id:
        print("Lỗi: Không có ID thiết bị. Dừng chương trình.")
        return

    # 2. Nhập danh sách Active Code (Sửa lại tối ưu cho việc Copy-Paste trên điện thoại)
    print("\n--- NHẬP DANH SÁCH CODE ---")
    print("Gợi ý: Dán toàn bộ code vào đây. (Nếu bị dính nhau, cách nhau bằng dấu phẩy hoặc dấu cách đều được).")
    print("Nhập chữ 'XONG' (hoặc nhấn Enter ở dòng trống) để BẮT ĐẦU CHẠY.")
    print("---------------------------")
    
    active_codes = []
    while True:
        try:
            line = input()
            # Nếu để trống hoặc nhập chữ "xong" -> Bắt đầu chạy
            if not line.strip() or line.strip().upper() == 'XONG':
                break
            
            codes_in_line = [c.strip() for c in line.replace(',', ' ').split() if c.strip()]
            active_codes.extend(codes_in_line)
            # Tắt in ra thông báo liên tục nếu paste quá nhiều (tránh ngợp Termux)
            # print(f"   -> Đã nhận {len(codes_in_line)} code...") 
        
        except EOFError:
            # Termux tự sinh EOF khi paste quá dài -> tự động chuyển sang bước tiếp theo
            print("\n[!] Nhận được tín hiệu ngắt từ Termux. Bắt đầu xử lý code đã nhập...")
            break
        except KeyboardInterrupt:
            print("\nĐã hủy.")
            return
    
    if not active_codes:
        print("Không tìm thấy code nào. Dừng chương trình.")
        return

    print(f"\nĐã nhận tổng cộng {len(active_codes)} code. Bắt đầu xử lý cho máy ID: {renew_id}...\n")

    # Vòng lặp xử lý từng code
    for index, code in enumerate(active_codes, 1):
        print(f"[{index}/{len(active_codes)}] Đang xử lý code: {code}...")
        
        # --- BƯỚC 1: Lấy thông tin Code (Có Retry Loop) ---
        step1_url = "https://api.vsphone.com/vsphone/api/vcGoodActivation/getGoodInfoByActiveCode"
        step1_params = {
            "activeCode": code,
            "isMonthNewVersion": "1"
        }
        
        info = None
        
        while True:
            try:
                resp1 = requests.get(step1_url, params=step1_params, headers=headers, timeout=10)
                
                if resp1.status_code != 200:
                    print(f"   -> Lỗi kết nối Bước 1 (HTTP {resp1.status_code}). Thử lại sau 2s...")
                    time.sleep(2)
                    continue
                    
                try:
                    data1 = resp1.json()
                except:
                    print("   -> Lỗi parse JSON Bước 1. Thử lại sau 2s...")
                    time.sleep(2)
                    continue
                
                msg = data1.get("msg", "")
                if data1.get("code") != 200 or not data1.get("data"):
                    if "too frequent" in msg.lower() or "quá thường xuyên" in msg.lower():
                        print(f"   -> Server báo quá nhanh Bước 1 ({msg})... Đợi 2s thử lại...")
                        time.sleep(2)
                        continue

                    if "was used on" in msg or "đã được sử dụng" in msg:
                        print(f"   -> Code đã qua sử dụng: {msg} -> BỎ QUA.")
                        break

                    print(f"   -> Lỗi Bước 1: {msg}")
                    break

                info = data1["data"]
                print(f"   -> Sản phẩm: {info.get('goodShowName', 'Unknown')}")
                break 

            except Exception as e:
                print(f"   -> Lỗi ngoại lệ Bước 1: {str(e)}. Đang thử lại sau 2s...")
                time.sleep(2)
                continue
        
        if not info:
            print("-" * 30)
            continue

        # --- BƯỚC 2: Đổi Code (Exchange) với cơ chế Retry ---
        step2_url = "https://api.vsphone.com/vsphone/api/vcGoodActivation/exchangeActiveCode"
        
        payload = {
            "activeGoodType": info.get("activeGoodType"),
            "goodId": info.get("goodId"),
            "activeCodeId": info.get("activeCodeId"),
            "activeCode": info.get("activeCode"),
            "countryCode": info.get("countryCode"),
            "goodTimeId": info.get("goodTimeId"),
            "isMonthNewVersion": True,
            "renewEquipmentIds": renew_id
        }

        while True:
            try:
                resp2 = requests.post(step2_url, json=payload, headers=headers, timeout=10)
                
                if resp2.status_code == 200:
                    try:
                        result2 = resp2.json()
                    except json.JSONDecodeError:
                        print("   -> Lỗi parse JSON từ server Bước 2. Đợi 2s thử lại...")
                        time.sleep(2)
                        continue

                    msg = result2.get("msg", "")

                    if result2.get("code") == 200:
                        print(f"   -> THÀNH CÔNG! {msg}")
                        break 
                    
                    elif "too frequent" in msg.lower() or "quá thường xuyên" in msg.lower():
                        print(f"   -> Server báo quá nhanh ({msg})... Đợi 2s rồi thử lại...")
                        time.sleep(2)
                        continue 
                    
                    else:
                        print(f"   -> THẤT BẠI Bước 2: {msg}")
                        break 
                
                elif resp2.status_code == 524 or (500 <= resp2.status_code < 600):
                    print(f"   -> Lỗi Server Bước 2 (HTTP {resp2.status_code}). Thử lại sau 2s...")
                    time.sleep(2)
                    continue
                
                else:
                    print(f"   -> Lỗi HTTP Bước 2: {resp2.status_code}")
                    break

            except Exception as e:
                print(f"   -> Lỗi kết nối Bước 2: {str(e)}. Thử lại sau 2s...")
                time.sleep(2)
                continue
        
        time.sleep(1)
        print("-" * 30)

    print("\nHoàn tất toàn bộ danh sách.")

if __name__ == "__main__":
    exchange_code()
