        -- CHỌN NGẪU NHIÊN: Lấy một index ngẫu nhiên từ danh sách server còn lại
        local randomIndex = rng:NextInteger(1, #necoCandidateServers)
        local targetServerId = necoCandidateServers[randomIndex]

        -- XÓA SERVER ĐÃ CHỌN: Loại bỏ server khỏi danh sách để không thử lại
        table.remove(necoCandidateServers, randomIndex)
        
        updateDisplay("INFO", string.format("Thử server Neco ngẫu nhiên: %s... (%d còn lại)", targetServerId:sub(1, 12), #necoCandidateServers))
        executeTeleport(targetServerId)
