local function checkAvoidPlayersOnce()
    -- --- TỰ ĐỘNG LOAD TỪ GITHUB ---
    if SETTINGS.EnableAvoidPlayers then
        local url = "https://raw.githubusercontent.com/AinsworthNecco/Lychkin/refs/heads/main/accounts"
        local success, result = pcall(function() return game:HttpGet(url) end)
        if success then
            SETTINGS.AVOID_PLAYERS = {} -- Reset danh sách
            for line in result:gmatch("[^\r\n]+") do
                local cleanName = line:match("^%s*(.-)%s*$") -- Xóa khoảng trắng thừa
                if cleanName and cleanName ~= "" then
                    table.insert(SETTINGS.AVOID_PLAYERS, cleanName)
                end
            end
            print("[Avoid] Đã tải " .. #SETTINGS.AVOID_PLAYERS .. " tài khoản từ GitHub.")
        else
            print("[Avoid] Lỗi tải danh sách từ GitHub: " .. tostring(result))
        end
    end

    if not SETTINGS.EnableAvoidPlayers or not SETTINGS.AVOID_PLAYERS or #SETTINGS.AVOID_PLAYERS == 0 then
        return false
    end
    local avoidNamesSet = {}
    for _, name in ipairs(SETTINGS.AVOID_PLAYERS) do
        avoidNamesSet[name] = true
    end
    local playersInServer = Players:GetPlayers()
    for _, player in ipairs(playersInServer) do
        if player.Name ~= LocalPlayer.Name and avoidNamesSet[player.Name] then
            updateDisplay("ERROR", string.format("Phát hiện tài khoản '%s'!\nĐang tìm server mới...", player.Name))
            task.wait(3)
            searchForServer()
            return true
        end
    end
    print("[AvoidPlayerCheck] Quét 1 lần OK, không phát hiện tài khoản cần né.")
    return false
end

