def get_inventory_slots():
    slots = []
    cell_w = (INV_RIGHT - INV_LEFT) / INV_COLS
    cell_h = (INV_BOTTOM - INV_TOP) / INV_ROWS
    for row in range(INV_ROWS):
        for col in range(INV_COLS):
            x = int(INV_LEFT + cell_w * col + cell_w / 2)
            y = int(INV_TOP + cell_h * row + cell_h / 2)
            slots.append((x, y))
    return slots

def get_chest_slots():
    slots = []
    cell_w = (CHEST_INV_RIGHT - CHEST_INV_LEFT) / CHEST_INV_COLS
    cell_h = (CHEST_INV_BOTTOM - CHEST_INV_TOP) / CHEST_INV_ROWS
    for row in range(CHEST_INV_ROWS):
        for col in range(CHEST_INV_COLS):
            x = int(CHEST_INV_LEFT + cell_w * col + cell_w / 2)
            y = int(CHEST_INV_TOP + cell_h * row + cell_h / 2)
            slots.append((x, y))
    return slots

INVENTORY_SLOTS = get_inventory_slots()
