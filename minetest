def restart_minecraft(ctrl):
    print("\n" + "="*40)
    print("[RESTART] 🔄 AUTO RESTART MINECRAFT")
    print("="*40)
    kill_minecraft(ctrl)
    time.sleep(3)
    launch_minecraft(ctrl)

def open_sell_menu(ctrl):
    print("\n[SELL] Mở /sell menu...")
    ctrl.send_command("sell")
    time.sleep(2.0)

    print("[SELL] Scroll danh sách sell...")
    ctrl.swipe(750, 700, 750, 200, duration=1000)
    time.sleep(1.0)

def spam_sell_slots(ctrl):
    print("[SELL] Double click 36 ô inventory...")
    duration = DOUBLE_CLICK_DURATION_MS
    delay = DOUBLE_CLICK_DELAY_MS / 1000

    for i, (x, y) in enumerate(INVENTORY_SLOTS):
        ctrl.run_cmd(f"input swipe {x} {y} {x} {y} {duration}")
        time.sleep(delay)
        ctrl.run_cmd(f"input swipe {x} {y} {x} {y} {duration}")
        time.sleep(delay)

    print("[SELL] Double click nút Sell...")
    ctrl.run_cmd(f"input swipe 700 950 700 950 80")
    time.sleep(0.05)
    ctrl.run_cmd(f"input swipe 700 950 700 950 80")
    time.sleep(1.0)

def idle_wait(ctrl, seconds):
    print(f"[*] Idle {seconds}s...")
    elapsed = 0
    while elapsed < seconds:
        if random.random() < 0.2:
            ctrl.jump()
        time.sleep(1)
        elapsed += 1

def run_sell_loop(ctrl):
    print("\n[*] Bắt đầu sell loop...")
    open_sell_menu(ctrl)

    while True:
        spam_sell_slots(ctrl)
        time.sleep(1.0)

        print("\n[CHECK] Kiểm tra tiền...")
        money = get_bot_money()

        if money is not None and money >= MIN_PAY_THRESHOLD:
            print(f"[CHECK] ✅ Đủ {money:,}! Thoát sell...")

            ctrl.send_key(KEY_ESCAPE)
            time.sleep(1.5)

            print(f"[PAY] 💸 Pay {money:,} -> {MAIN_ACCOUNT}")
            ctrl.send_command(f"pay {MAIN_ACCOUNT} {money}")
            time.sleep(2.0)

            # Nghỉ random trước khi vào sell lại
            delay = random.randint(MIN_LOOP_DELAY, MAX_LOOP_DELAY)
            print(f"[*] Nghỉ {delay}s trước khi sell tiếp...")
            idle_wait(ctrl, delay)

            # Vào lại sell
            open_sell_menu(ctrl)

        else:
            money_str = f"{money:,}" if money else "N/A"
            print(f"[CHECK] ⏳ Chưa đủ ({money_str}), tiếp tục sell...")

def main():
    print(f"[*] START IN {START_DELAY}S")
    for i in range(START_DELAY, 0, -1):
        print(f"{i}s...")
        time.sleep(1)

    ctrl = InputController(use_su=True)

    enable_wake_lock(ctrl)
    launch_minecraft(ctrl)

    last_restart_time = time.time()

    while True:
        try:
            # Check restart
            if RESTART_ENABLED:
                elapsed = time.time() - last_restart_time
                if elapsed >= RESTART_INTERVAL:
                    restart_minecraft(ctrl)
                    enable_wake_lock(ctrl)
                    last_restart_time = time.time()

            run_sell_loop(ctrl)

        except KeyboardInterrupt:
            print("\n[!] Stopped. Exiting...")
            ctrl.run_cmd("settings put system screen_off_timeout 60000")
            ctrl.run_cmd("svc power stayon false")
            break
        except Exception as e:
            print(f"\n[!] Error: {e}. Retrying in 5s...")
            time.sleep(5)

if __name__ == "__main__":
    main()
