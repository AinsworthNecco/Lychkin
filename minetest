def open_sell_menu(ctrl):
    print("\n[SELL] Mở /sell menu...")
    ctrl.send_command("sell")
    time.sleep(2.0)

    print("[SELL] Scroll danh sách sell...")
    ctrl.swipe(750, 700, 750, 200, duration=1000)
    time.sleep(1.0)

def do_sell_cycle(ctrl):
    """1 cycle = 36 cặp click + nhấn sell + xác nhận"""
    duration = CLICK_DURATION_MS
    delay = CLICK_DELAY_MS / 1000

    # 36 cặp click xen kẽ
    for i in range(28):
        inv_x, inv_y = INVENTORY_SLOTS[i]
        chest_x, chest_y = CHEST_SLOTS[i]
        ctrl.run_cmd(f"input swipe {inv_x} {inv_y} {inv_x} {inv_y} {duration}")
        time.sleep(delay)
        ctrl.run_cmd(f"input swipe {chest_x} {chest_y} {chest_x} {chest_y} {duration}")
        time.sleep(delay)

    # Nhấn nút Sell
    print("[SELL] Nhấn Sell...")
    ctrl.run_cmd(f"input swipe 705 940 705 940 {duration}")
    time.sleep(delay)

    # Nhấn xác nhận
    print("[SELL] Xác nhận...")
    ctrl.run_cmd(f"input swipe 620 940 620 940 {duration}")
    time.sleep(0.5)

def idle_wait(seconds):
    print(f"[*] Idle {seconds}s...")
    time.sleep(seconds)

def run_sell_loop(ctrl):
    print("\n[*] Bắt đầu sell loop...")
    open_sell_menu(ctrl)

    cycle_count = 0
    money_state["enough"] = False
    money_state["value"] = None

    while True:
        # Chạy 1 cycle sell
        do_sell_cycle(ctrl)
        cycle_count += 1
        print(f"[SELL] Cycle #{cycle_count} xong")

        # Mỗi 10 cycle thì check tiền song song
        if cycle_count % CHECK_EVERY_N_CYCLES == 0:
            print(f"[CHECK] Trigger check tiền (cycle {cycle_count})...")
            t = threading.Thread(target=check_money_async, daemon=True)
            t.start()

        # Nếu đã check xong và đủ tiền thì dừng sau cycle hiện tại
        if money_state["enough"]:
            print(f"[CHECK] ✅ Đủ tiền! Kết thúc vòng lặp sell...")
            break

    # Thoát sell menu
    ctrl.send_key(KEY_ESCAPE)
    time.sleep(1.5)

    # Pay
    money = money_state["value"]
    print(f"[PAY] 💸 Pay {money:,} -> {MAIN_ACCOUNT}")
    ctrl.send_command(f"pay {MAIN_ACCOUNT} {money}")
    time.sleep(2.0)

    # Reset state
    money_state["enough"] = False
    money_state["value"] = None
    cycle_count = 0

    # Nghỉ random
    delay = random.randint(MIN_LOOP_DELAY, MAX_LOOP_DELAY)
    print(f"[*] Nghỉ {delay}s trước khi sell tiếp...")
    idle_wait(delay)

    # Vào lại sell
    open_sell_menu(ctrl)

def main():
    print(f"[*] START IN {START_DELAY}S")
    for i in range(START_DELAY, 0, -1):
        print(f"{i}s...")
        time.sleep(1)

    ctrl = InputController(use_su=True)

    enable_wake_lock(ctrl)
    launch_minecraft(ctrl)

    last_restart_time = time.time()

    while True:
        try:
            if RESTART_ENABLED:
                elapsed = time.time() - last_restart_time
                if elapsed >= RESTART_INTERVAL:
                    restart_minecraft(ctrl)
                    enable_wake_lock(ctrl)
                    last_restart_time = time.time()

            run_sell_loop(ctrl)

        except KeyboardInterrupt:
            print("\n[!] Stopped. Exiting...")
            ctrl.run_cmd("settings put system screen_off_timeout 60000")
            ctrl.run_cmd("svc power stayon false")
            break
        except Exception as e:
            print(f"\n[!] Error: {e}. Retrying in 5s...")
            time.sleep(5)

if __name__ == "__main__":
    main()
