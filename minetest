import time
import os

MAIN_ACCOUNT = "xxstylexx21"
PAY_AMOUNT = "50k"
SELL_PRICE = "50k"
START_DELAY = 5

CHEST_BLOCK_X = 500
CHEST_BLOCK_Y = 250
CHEST_SLOT_1_X = 580
CHEST_SLOT_1_Y = 100

KEY_ESCAPE = "4"
KEY_CHAT = "76"
KEY_ENTER = "66"

SEND_BTN_X = 900
SEND_BTN_Y = 500

class InputController:
    def __init__(self, use_su=True):
        self.use_su = use_su
        print(f"[*] Controller: {'Root (su)' if use_su else 'ADB'}")

    def run_cmd(self, command):
        if self.use_su:
            os.system(f"su -c '{command}'")
        else:
            os.system(f"adb shell {command}")

    def tap(self, x, y, duration=150):
        print(f" -> Tap: ({x}, {y}) for {duration}ms")
        self.run_cmd(f"input swipe {x} {y} {x} {y} {duration}")
        time.sleep(0.5)

    def double_click(self, x, y):
        print(f" -> Double Click: ({x}, {y})")
        self.run_cmd(f"input swipe {x} {y} {x} {y} 50")
        time.sleep(0.1)
        self.run_cmd(f"input swipe {x} {y} {x} {y} 50")
        time.sleep(0.5)

    def send_key(self, keycode):
        print(f" -> Key: {keycode}")
        self.run_cmd(f"input keyevent {keycode}")
        time.sleep(0.5)

    def send_command(self, cmd_text):
        print(f"[CMD] Sending: /{cmd_text}")

        # Step 1: Open chat
        self.run_cmd(f"input keyevent {KEY_CHAT}")
        time.sleep(1.5)

        # Step 2: Type slash
        self.run_cmd("input text /")
        time.sleep(0.5)

        # Step 3: Type command word by word
        parts = cmd_text.lstrip("/").split(" ")
        for i, part in enumerate(parts):
            self.run_cmd(f"input text '{part}'")
            time.sleep(0.4)
            if i < len(parts) - 1:
                self.run_cmd("input keyevent 62")  # space
                time.sleep(0.3)

        time.sleep(0.8)

        # Step 4: First tap to focus the send button
        print(" -> Tap 1: Focus send button...")
        self.tap(SEND_BTN_X, SEND_BTN_Y, duration=300)
        time.sleep(0.8)

        # Step 5: Second tap to actually send
        print(" -> Tap 2: Send!")
        self.tap(SEND_BTN_X, SEND_BTN_Y, duration=300)
        time.sleep(2.0)

def main():
    print(f"[*] START IN {START_DELAY}S")
    for i in range(START_DELAY, 0, -1):
        print(f"{i}s...")
        time.sleep(1)

    ctrl = InputController(use_su=True)

    print("\n[STEP 0]: OPEN CHEST")
    ctrl.tap(CHEST_BLOCK_X, CHEST_BLOCK_Y)
    time.sleep(2.0)

    print("\n[STEP 1]: TAKE ITEM")
    ctrl.double_click(CHEST_SLOT_1_X, CHEST_SLOT_1_Y)
    time.sleep(1.0)

    print("\n[STEP 2]: CLOSE CHEST")
    ctrl.send_key(KEY_ESCAPE)
    time.sleep(3.0)

    print("\n[STEP 3]: SELL")
    ctrl.send_command(f"ah sell {SELL_PRICE}")
    time.sleep(2.0)

    print("\n[STEP 4]: PAY")
    ctrl.send_command(f"pay {MAIN_ACCOUNT} {PAY_AMOUNT}")
    time.sleep(2.0)

    print("\n[DONE]")

if __name__ == "__main__":
    main()
