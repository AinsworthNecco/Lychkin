# Tọa độ 36 ô inventory (4 cột x 9 hàng)
INV_LEFT = 85
INV_TOP = 105
INV_RIGHT = 415
INV_BOTTOM = 855  # 👈 Đã sửa
INV_COLS = 4
INV_ROWS = 9

def get_inventory_slots():
    slots = []
    cell_w = (INV_RIGHT - INV_LEFT) / INV_COLS
    cell_h = (INV_BOTTOM - INV_TOP) / INV_ROWS
    for row in range(INV_ROWS):
        for col in range(INV_COLS):
            x = int(INV_LEFT + cell_w * col + cell_w / 2)
            y = int(INV_TOP + cell_h * row + cell_h / 2)
            slots.append((x, y))
    return slots

INVENTORY_SLOTS = get_inventory_slots()

def get_bot_money():
    try:
        headers = {
            "Authorization": f"Bearer {API_KEY}",
            "User-Agent": "Mozilla/5.0"
        }
        url = f"https://api.donutsmp.net/v1/stats/{BOT_USERNAME}"
        res = requests.get(url, headers=headers, timeout=10)
        data = res.json()
        money = data.get("result", {}).get("money")
        if money is not None:
            money_int = int(str(money).replace(",", "").replace(".", ""))
            print(f"[API] 💰 Tiền hiện tại: {money_int:,}")
            return money_int
        else:
            print(f"[API] ❌ Không tìm thấy money")
            return None
    except Exception as e:
        print(f"[API] ❌ Lỗi: {e}")
        return None

class InputController:
    def __init__(self, use_su=True):
        self.use_su = use_su
        print(f"[*] Controller: {'Root (su)' if use_su else 'ADB'}")

    def run_cmd(self, command):
        if self.use_su:
            os.system(f"su -c '{command}'")
        else:
            os.system(f"adb shell {command}")

    def tap(self, x, y, duration=150):
        print(f" -> Tap: ({x}, {y}) for {duration}ms")
        self.run_cmd(f"input swipe {x} {y} {x} {y} {duration}")
        time.sleep(0.5)

    def tap_random(self, x, y, duration=300):
        rx = x + random.randint(-4, 4)
        ry = y + random.randint(-4, 4)
        print(f" -> Tap (random): ({rx}, {ry}) for {duration}ms")
        self.run_cmd(f"input swipe {rx} {ry} {rx} {ry} {duration}")
        time.sleep(0.5)

    def double_click(self, x, y):
        delay = DOUBLE_CLICK_DELAY_MS / 1000
        self.run_cmd(f"input swipe {x} {y} {x} {y} 80")
        time.sleep(delay)
        self.run_cmd(f"input swipe {x} {y} {x} {y} 80")
        time.sleep(delay)

    def swipe(self, x1, y1, x2, y2, duration=1000):
        print(f" -> Swipe: ({x1},{y1}) -> ({x2},{y2}) for {duration}ms")
        self.run_cmd(f"input swipe {x1} {y1} {x2} {y2} {duration}")
        time.sleep(0.5)

    def send_key(self, keycode):
        print(f" -> Key: {keycode}")
        self.run_cmd(f"input keyevent {keycode}")
        time.sleep(0.5)

    def jump(self):
        print(f" -> 🐸 Jump!")
        self.run_cmd(f"input keyevent {KEY_SPACE}")
        time.sleep(0.3)

    def send_command(self, cmd_text):
        print(f"[CMD] Sending: /{cmd_text}")

        self.run_cmd(f"input keyevent {KEY_CHAT}")
        time.sleep(2.0)

        self.run_cmd("input text /")
        time.sleep(0.8)

        full_cmd = cmd_text.lstrip("/")
        for char in full_cmd:
            if char == " ":
                self.run_cmd("input keyevent 62")
            else:
                safe_char = char.replace("'", "\\'")
                self.run_cmd(f"input text '{safe_char}'")
            time.sleep(0.15)

        time.sleep(1.0)

        print(f" -> Send tap...")
        self.tap_random(SEND_BTN_X, SEND_BTN_Y, duration=300)
        time.sleep(2.0)

def enable_wake_lock(ctrl):
    print("\n[WAKE] 🔒 Bật wake lock...")
    ctrl.run_cmd("settings put system screen_off_timeout 2147483647")
    ctrl.run_cmd("dumpsys deviceidle disable")
    ctrl.run_cmd("svc power stayon true")
    ctrl.run_cmd("input keyevent 224")
    time.sleep(1)
    print("[WAKE] ✅ Wake lock đã bật!")

def kill_minecraft(ctrl):
    print("\n[RESTART] 🔴 Đang tắt Minecraft...")
    ctrl.run_cmd(f"am force-stop {MC_PACKAGE}")
    time.sleep(3)
    ctrl.run_cmd(f"killall {MC_PACKAGE}")
    time.sleep(2)
    print("[RESTART] ✅ Minecraft đã tắt!")

