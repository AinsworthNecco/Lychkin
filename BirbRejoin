#!/data/data/com.termux/files/usr/bin/bash

# ==========================================
# CẤU HÌNH CƠ BẢNsu -c "wm size 1280x2120"
# ==========================================
CHECK_INTERVAL=300            # Thời gian quét (giây) -> 300s = 5 phút

# Hỗ trợ cả ID thường (VD: 8737602449) HOẶC Link Share/VIP (VD: https://www.roblox.com/share?...)
JOIN_TARGET="https://www.roblox.com/share?code=98a1b858bf53db43b688552818e40748&type=Server"

BASE_PACKAGE_NAME="com.roblox.clien" # Tên gói Roblox cơ bản
ACCOUNT_SUFFIXES="b c d e f"         # Hậu tố của các bản clone

# ==========================================
# CÁC HÀM XỬ LÝ
# ==========================================

setup_display() {
    echo "[SETUP] Lychkin"
    su -c "wm size 1200x1000"
    su -c "wm density 200"
    sleep 2
    echo "[SETUP] Hoàn tất thiết lập màn hình!"
    echo ""
}

is_running() {
    local pkg=$1
    # Kiểm tra tiến trình đang chạy (bỏ qua dòng lệnh grep)
    local output=$(su -c "ps -ef | grep $pkg | grep -v grep")
    
    if [[ -n "$output" ]]; then
        return 0 # Đang chạy (True)
    else
        return 1 # Đã tắt (False)
    fi
}

launch_app() {
    local pkg=$1
    local deeplink="$JOIN_TARGET"
    
    # Nhận diện: Nếu JOIN_TARGET chỉ chứa các con số (ID thường), thì ghép thêm mác roblox://
    if [[ "$deeplink" =~ ^[0-9]+$ ]]; then
        deeplink="roblox://placeId=${deeplink}"
    fi
    
    # Bật chế độ cửa sổ (5) + Truyền trực tiếp link (HTTPS hoặc Deeplink) + Chỉ định package
    su -c "am start --windowingMode 5 -a android.intent.action.VIEW -d '${deeplink}' -p ${pkg}"
}

# ==========================================
# CHƯƠNG TRÌNH CHÍNH
# ==========================================

# Ép Termux chạy ngầm không bị sleep (không cần root cho lệnh này)
termux-wake-lock

echo "======================================="
echo "  AUTO RESTARTER LITE (BASH SCRIPT)  "
echo "======================================="
echo ""

# 1. Setup màn hình
setup_display

# 2. Vòng lặp kiểm tra liên tục
while true; do
    current_time=$(date +"%H:%M:%S")
    echo "[$current_time] Bắt đầu vòng quét mới..."
    
    # Tự động tách chuỗi ACCOUNT_SUFFIXES và duyệt qua từng số/chữ
    for suffix in $ACCOUNT_SUFFIXES; do
        pkg="${BASE_PACKAGE_NAME}${suffix}"
        
        if is_running "$pkg"; then
            echo "  [OK] $pkg đang chạy -> Bỏ qua (Skip)."
        else
            echo "  [START] $pkg đã tắt -> Đang mở lại dạng cửa sổ..."
            launch_app "$pkg"
            # Đợi 5 giây giữa các lần mở app để tránh treo máy
            sleep 5
        fi
    done
    
    echo ""
    echo "[SLEEP] Đợi ${CHECK_INTERVAL} giây trước vòng quét tiếp theo..."
    echo ""
    sleep $CHECK_INTERVAL
done
