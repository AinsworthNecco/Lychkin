#!/data/data/com.termux/files/usr/bin/python
# -*- coding: utf-8 -*-

import subprocess
import time
import sys

# ==========================================
# CẤU HÌNH CƠ BẢN
# ==========================================
CHECK_INTERVAL = 300  # Thời gian quét (giây) -> 300s = 5 phút
PLACE_ID = "https://www.roblox.com/share?code=98a1b858bf53db43b688552818e40748&type=Server" # ID của game cần quét

BASE_PACKAGE_NAME = "com.roblox.clien" # Tên gói Roblox cơ bản
ACCOUNT_SUFFIXES = "2 3 4 5 6"

# Danh sách các bản clone cần quản lý (Tự động tạo: com.roblox.clien2, com.roblox.clien3...)
PACKAGES = [f"{BASE_PACKAGE_NAME}{suffix}" for suffix in ACCOUNT_SUFFIXES.split()]

def run_su_cmd(cmd):
    """Chạy lệnh dưới quyền Root (su -c)"""
    try:
        result = subprocess.run(["su", "-c", cmd], capture_output=True, text=True)
        return result.stdout.strip()
    except Exception as e:
        print(f"[LỖI HỆ THỐNG] Không thể chạy lệnh: {e}")
        return ""

def setup_display():
    """Thiết lập độ phân giải và DPI theo yêu cầu"""
    print("[SETUP] Đang thiết lập màn hình (1080x1920, DPI 300)...")
    run_su_cmd("wm size 1080x1920")
    run_su_cmd("wm density 300")
    time.sleep(2) # Đợi hệ thống áp dụng
    print("[SETUP] Hoàn tất thiết lập màn hình!\n")

def is_running(pkg_name):
    """Kiểm tra xem package có đang chạy không"""
    output = run_su_cmd(f"ps -ef | grep {pkg_name} | grep -v grep")
    # Nếu output có chứa tên package, nghĩa là nó đang chạy
    if pkg_name in output:
        return True
    return False

def launch_app(pkg_name):
    """Mở app dưới dạng cửa sổ và join thẳng vào game"""
    # Bạn có thể thay đổi deeplink (roblox://...) ở đây nếu dùng link VIP server cụ thể
    deeplink = f"roblox://placeId={PLACE_ID}"
    
    # Lệnh kết hợp: Bật chế độ cửa sổ (5) + Truyền link game (VIEW) + Chỉ định đúng package
    cmd = (
        f"am start --windowingMode 5 "
        f"-a android.intent.action.VIEW "
        f"-d '{deeplink}' "
        f"-p {pkg_name}"
    )
    
    run_su_cmd(cmd)

def main():
    print("=======================================")
    print("  AUTO RESTARTER LITE (WINDOW MODE) ")
    print("=======================================\n")
    
    # 1. Setup màn hình trước tiên
    setup_display()
    
    # 2. Vòng lặp kiểm tra liên tục
    while True:
        print(f"[{time.strftime('%H:%M:%S')}] Bắt đầu vòng quét mới...")
        
        for pkg in PACKAGES:
            if is_running(pkg):
                print(f"  [OK] {pkg} đang chạy -> Bỏ qua (Skip).")
            else:
                print(f"  [START] {pkg} đã tắt -> Đang mở lại dạng cửa sổ...")
                launch_app(pkg)
                # Đợi 5 giây giữa các lần mở app để tránh treo máy
                time.sleep(5)
                
        print(f"\n[SLEEP] Đợi {CHECK_INTERVAL} giây trước vòng quét tiếp theo...\n")
        time.sleep(CHECK_INTERVAL)

if __name__ == "__main__":
    # Ép Termux chạy ngầm không bị sleep
    run_su_cmd("termux-wake-lock")
    main()
