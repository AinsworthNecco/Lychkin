def initial_setup(accounts):
    ui_log("SETUP", "Tiến hành tải danh sách Cookie từ GITHUB_URL_A...")
    data = fetch_github_file(GITHUB_URL_A)
    if not data:
        ui_log("SETUP", "Lỗi tải data từ A! Không có data để thiết lập.")
        return

    lines = [l.strip() for l in data.splitlines() if l.strip()]
    
    for i, acc in enumerate(accounts):
        if i >= len(lines):
            ui_log("SETUP", f"Cảnh báo: File A đã hết data. Tab '{acc['suffix']}' không có cookie!")
            continue
            
        line = lines[i]
        parts = line.split(":", 2)
        if len(parts) == 3:
            user, pwd, raw_cookie = parts
            
            # Tự động giải mã "neco" nếu cookie bị mã hóa
            idx = raw_cookie.find("_|WARNING:-DO-NOT-SHARE")
            if idx != -1 and len(raw_cookie) >= idx + 174 and raw_cookie[idx+170:idx+174] == "neco":
                decoded_cookie = raw_cookie[:idx+170] + raw_cookie[idx+174:]
            else:
                decoded_cookie = raw_cookie
                
            # Lưu user:pass vào bộ nhớ đệm của acc để tí nữa xuất ra B
            acc['user'] = user
            acc['pass'] = pwd
            
            local = get_local_cookie(acc['pkg'])
            if local != decoded_cookie:
                ui_log("INJECT", f"Đang bơm Cookie A cho tab '{acc['suffix']}'...")
                if inject_cookie_process(acc['pkg'], decoded_cookie):
                    acc['id'] = get_roblox_user_id(decoded_cookie)
            else:
                ui_log("INJECT", f"Tab '{acc['suffix']}' đã khớp Cookie A.")
                acc['id'] = get_roblox_user_id(decoded_cookie)
                
            ui_log("INJECT", f"ID tìm thấy cho '{acc['suffix']}': {acc.get('id', '0')}")
        else:
            ui_log("SETUP", f"Lỗi định dạng dòng {i+1} ở A. Yêu cầu dạng (user:pass:cookie).")

def sync_cookies_to_github_B(accounts):
    """Lấy cookie dưới máy đẩy lên Github B (Giữ user:pass). Ghi nối tiếp."""
    ui_log("SYNC", "Nhận lệnh YES! Đang xuất data lên Github_URL_B...")
    
    # Lấy data cũ từ B để ghi nối tiếp (Append)
    data_b = fetch_github_file(GITHUB_URL_B)
    if data_b is None:
        data_b = ""
        
    new_batch_lines = []
    for acc in accounts:
        # Chỉ đẩy lên B nếu account này đã có user và pass từ file A
        if 'user' in acc and 'pass' in acc:
            local_val = get_local_cookie(acc['pkg'])
            if local_val:
                # Định dạng Raw, không bọc neco
                new_batch_lines.append(f"{acc['user']}:{acc['pass']}:{local_val}")
                
    if not new_batch_lines:
        ui_log("SYNC", "Không có Cookie hợp lệ nào dưới máy để xuất!")
        return
        
    new_batch_str = "\n".join(new_batch_lines)
    
    # Ghi đè vào B: Nếu B đã có chữ thì cách ra 1 dòng trống (\n\n) trước khi ghi batch mới
    if data_b.strip():
        final_content = data_b.rstrip() + "\n\n" + new_batch_str
    else:
        final_content = new_batch_str
        
    if update_github_file(GITHUB_URL_B, final_content):
        ui_log("SYNC", "Đã xuất data mới nhất nối tiếp vào Github B thành công!")
    else:
        ui_log("SYNC", "Lỗi: Không thể Push lên Github B.")

