def click_text_on_screen(target_text, partial_match=False):
    """Quét màn hình và click vào tọa độ chứa văn bản (Bất chấp thứ tự XML)."""
    dump_file = "/data/local/tmp/uidump.xml"
    run_root_cmd(f"rm -f {dump_file}")
    
    # Dump giao diện UI hiện tại ra file XML
    out, _ = run_root_cmd(f"uiautomator dump {dump_file}")
    if "dumped" not in out and "UI" not in out:
        time.sleep(0.5)
        return False
        
    dump_content, _ = run_root_cmd(f"cat {dump_file}")
    
    if dump_content:
        target_lower = target_text.lower()
        # Bắt toàn bộ thẻ node
        pattern = r'<node(.*?)>'
        for match in re.finditer(pattern, dump_content):
            node_attrs = match.group(1)
            
            # Tìm thuộc tính riêng lẻ, giải quyết triệt để lỗi thứ tự đảo lộn trên MuMu
            text_m = re.search(r'text="([^"]*)"', node_attrs)
            desc_m = re.search(r'content-desc="([^"]*)"', node_attrs)
            bounds_m = re.search(r'bounds="\[(\d+),(\d+)\]\[(\d+),(\d+)\]"', node_attrs)
            
            text = text_m.group(1) if text_m else ""
            desc = desc_m.group(1) if desc_m else ""
            content = (text + " " + desc).lower()
            
            if not content.strip():
                continue
                
            is_match = False
            if partial_match and target_lower in content:
                is_match = True
            elif not partial_match and (target_lower == text.lower() or target_lower == desc.lower()):
                is_match = True
                
            if is_match and bounds_m:
                x1, y1, x2, y2 = map(int, bounds_m.groups())
                center_x = (x1 + x2) // 2
                center_y = (y1 + y2) // 2
                
                # DÙNG SWIPE 100ms ĐỂ HIỂN THỊ RÕ CHẤM CHẠM VÀ TRÁNH BỊ MISS TAP
                print(f"    -> Đang click (UIAutomator) tại: ({center_x}, {center_y})")
                run_root_cmd(f"input swipe {center_x} {center_y} {center_x} {center_y} 100")
                return True
                
    return False

