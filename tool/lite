def run_root_cmd(command):
    try:
        full_cmd = f"su -c '{command}'"
        result = subprocess.run(full_cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=10)
        return result.stdout.strip(), result.returncode
    except Exception:
        return None, -1

def get_android_id():
    out, _ = run_root_cmd("settings get secure android_id")
    if out and len(out) > 5:
        return out.strip()
    return "UNKNOWN_DEVICE_ID"

def auto_detect_roblox_packages():
    out, _ = run_root_cmd(f"pm list packages | grep {BASE_PACKAGE_NAME}")
    accounts = []
    if out:
        for line in out.splitlines():
            pkg = line.replace("package:", "").strip()
            if pkg.startswith(BASE_PACKAGE_NAME):
                suffix = pkg[len(BASE_PACKAGE_NAME):]
                accounts.append({'suffix': suffix, 'pkg': pkg})
                
    sorted_accounts = sorted(accounts, key=lambda x: x['suffix'])
    
    # Cắt giảm số lượng tab theo ACCOUNT_NUMBER
    if ACCOUNT_NUMBER > 0:
        sorted_accounts = sorted_accounts[:ACCOUNT_NUMBER]
        
    return sorted_accounts

def check_root_access():
    out, _ = run_root_cmd("whoami")
    return out == "root"

def get_local_github_token():
    if OBFUSCATED_GITHUB_TOKEN and OBFUSCATED_GITHUB_TOKEN.startswith("neco") and OBFUSCATED_GITHUB_TOKEN.endswith("neco"):
        core_token = OBFUSCATED_GITHUB_TOKEN[4:-4]
        return f"ghp_{core_token}"
    return None

def extract_github_info(url):
    match = re.search(r'raw\.githubusercontent\.com/([^/]+)/([^/]+)/(?:refs/heads/)?([^/]+)/(.*)', url)
    if match:
        owner, repo, branch, path = match.groups()
        return f"{owner}/{repo}", path, branch
    return None, None, None

