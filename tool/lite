        print(f"[*] Đang mở ứng dụng ({app_package}) lần 1 để làm sạch dữ liệu cũ...")
        subprocess.run(["su", "-c", f"am start -a android.intent.action.VIEW -d {target_url} -p {app_package}"], capture_output=True)

        print(f"[*] Đang chờ {WAIT_BEFORE_SECOND_OPEN} giây trước khi khởi động lại App...")
        time.sleep(WAIT_BEFORE_SECOND_OPEN)

        print("[*] Đang tắt App để khởi động lại...")
        run_root_cmd(f"am force-stop {app_package}")
        time.sleep(WAIT_AFTER_FORCE_STOP)

        # Mở app lần 2 chính thức
        print(f"[*] Đang mở ứng dụng ({app_package}) lần 2 (Chính thức)...")
        subprocess.run(["su", "-c", f"am start -a android.intent.action.VIEW -d {target_url} -p {app_package}"], capture_output=True)

        # -- TIẾN HÀNH AUTO CLICK ĐIỀU KHOẢN HOẶC CHỜ TIMEOUT --
        auto_bypass_terms_screen()

        print("\n[*] Đang tắt App...")
        run_root_cmd(f"am force-stop {app_package}")
        time.sleep(WAIT_AFTER_FORCE_STOP)

        print("[*] Đang kiểm tra Cookie mới từ App...")
        new_cookie = get_local_cookie(app_package, old_cookie)

        is_success = False
        fail_reason = ""

        # --- BỘ LỌC ĐIỀU KIỆN COOKIE BẰNG API QUỐC GIA ---
        if new_cookie:
            if new_cookie == old_cookie:
                fail_reason = "Cookie không đổi (App chưa load/Cookie chết)"
            else:
                print("[*] Đang kiểm tra quốc gia của Cookie mới qua API...")
                if check_cookie_country(new_cookie):
                    is_success = True
                else:
                    fail_reason = "Quốc gia của Cookie chưa được chuyển sang Vietnam"
        else:
            fail_reason = "Không tìm thấy Cookie"

        # --- XỬ LÝ KẾT QUẢ VÀ WEBHOOK ---
        if is_success:
            print("\033[1;32m[*] Rút Cookie MỚI (Vietnam) thành công!\033[0m")
            new_line_data = f"{username}:{password}:{new_cookie}"

            data_B = fetch_github_file(GITHUB_URL_B)
            if data_B is None: data_B = ""
            
            b_lines = [l.strip() for l in data_B.splitlines() if l.strip()]
            b_lines.append(new_line_data)
            new_content_B = "\n".join(b_lines)

            if update_github_file(GITHUB_URL_B, new_content_B):
                print("\033[1;32m[+] THÀNH CÔNG: Đã lưu dữ liệu lên Github B!\033[0m")
                processed_usernames.add(username)
                send_discord_webhook(f"{disp_idx}/{total_accounts} - success ✅")
                
                # Dọn rác khỏi Github A sau khi đã xong
                print("[*] Đang dọn dẹp account này khỏi Github A...")
                remove_account_from_github_a(username)
            else:
                print("\033[1;31m[-] THẤT BẠI: Không thể push nội dung lên Github B.\033[0m")
                send_discord_webhook(f"{disp_idx}/{total_accounts} - failed (Github Push Error) ❌")
        else:
            print(f"\033[1;31m[-] LỖI: {fail_reason}\033[0m")
            print("[*] Đang kiểm tra tình trạng Cookie cũ...")
            
            is_live = check_cookie_live(old_cookie)
            
            if is_live:
                # Cookie còn sống, tiến hành giữ lại và retry
                if retries < MAX_RETRIES:
                    print(f"\033[1;33m[*] Cookie VẪN SỐNG. Sẽ NHÉT LẠI account này xuống CUỐI DANH SÁCH để thử lại sau!\033[0m")
                    account['retries'] += 1
                    queue.append(account)
                    send_discord_webhook(f"{disp_idx}/{total_accounts} - cookie not match requirement - retry 🔄")
                else:
                    print("\033[1;31m[-] Đã hết số lần thử lại nhưng Cookie vẫn sống. Bỏ qua (Không xóa khỏi A).\033[0m")
                    send_discord_webhook(f"{disp_idx}/{total_accounts} - failed (Max Retries) ❌")
            else:
                # Cookie đã chết ngắc, xóa sổ
                print("\033[1;31m[-] Cookie ĐÃ CHẾT. XÓA SỔ account khỏi Github A!\033[0m")
                remove_account_from_github_a(username)
                send_discord_webhook(f"{disp_idx}/{total_accounts} - failed (Dead Cookie) ❌")

        if len(queue) > 0:
            print(f"[*] Đang chuẩn bị thao tác tiếp theo sau {WAIT_BEFORE_NEXT_ACCOUNT} giây...")
            time.sleep(WAIT_BEFORE_NEXT_ACCOUNT)

    print("\n=======================================================")
    print("[*] HOÀN TẤT: Đã xử lý cạn kiệt toàn bộ Hàng Đợi (Queue)!")
    print("=======================================================")

