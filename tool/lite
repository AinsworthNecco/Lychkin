        if not uid or str(uid) == "0":
            continue
            
        ui_log("LAUNCH", f"Đang Force-stop và khởi động tab '{suffix}'...")
        run_root_cmd(f"am force-stop {pkg}")
        time.sleep(1)
        # Sử dụng monkey dể kích hoạt chính xác màn hình chính của mọi Launcher
        subprocess.run(["su", "-c", f"monkey -p {pkg} -c android.intent.category.LAUNCHER 1 > /dev/null 2>&1"], capture_output=True, timeout=10)
        time.sleep(5)
        
    ui_log("LAUNCH", "Đã mở xong toàn bộ tab. Bắt đầu vòng lặp check API...")
    
    formatted_proxies = format_proxies(PROXY_LIST)
    num_proxies = len(formatted_proxies)

    # Bước 2: Vòng lặp check Proxy liên tục
    while True:
        for acc in accounts:
            pkg = acc['pkg']
            uid = acc.get('id', "0")
            suffix = acc['suffix']
            
            is_process_active = check_process_running(pkg)
            should_launch = False
            
            if not uid or str(uid) == "0":
                ui_log("LAUNCH", f"Tab '{suffix}' không có Cookie/ID hợp lệ. Bỏ qua.")
                if is_process_active:
                    run_root_cmd(f"am force-stop {pkg}")
                continue

            if not is_process_active:
                ui_log("LAUNCH", f"Tab '{suffix}' đang TẮT -> Bật lên.")
                should_launch = True
            else:
                ui_log("LAUNCH", f"Tab '{suffix}' đang CHẠY -> Check API...")
                start_idx = random.randint(0, num_proxies - 1) if num_proxies > 0 else -1
                is_online = check_roblox_presence_single(uid, formatted_proxies, start_idx)
                
                if is_online:
                    ui_log("LAUNCH", f"Tab '{suffix}' ONLINE -> Skip.")
                    continue 
                else:
                    ui_log("LAUNCH", f"Tab '{suffix}' OFFLINE -> Tắt (Force-stop) & Bật lại.")
                    run_root_cmd(f"am force-stop {pkg}")
                    time.sleep(2)
                    should_launch = True

            if should_launch:
                ui_log("LAUNCH", f"Đang ra lệnh mở app: {pkg}")
                subprocess.run(["su", "-c", f"monkey -p {pkg} -c android.intent.category.LAUNCHER 1 > /dev/null 2>&1"], capture_output=True, timeout=10)
                time.sleep(5)
        
        ui_log("LAUNCH", f"Hoàn thành 1 vòng kiểm tra. Chờ {LAUNCH_INTERVAL_SECONDS}s...")
        countdown(LAUNCH_INTERVAL_SECONDS, "LAUNCH")

