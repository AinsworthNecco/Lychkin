def execute_api_request_simple(method, url, json_data=None, proxy=None):
    try:
        if method.upper() == 'GET': response = requests.get(url, proxies=proxy, timeout=CONNECTION_TIMEOUT)
        elif method.upper() == 'POST': response = requests.post(url, json=json_data, proxies=proxy, timeout=CONNECTION_TIMEOUT)
        if response.status_code == 200: return response.json()
    except Exception: pass 
    return None

def check_roblox_presence_single(account_id, proxy_list, initial_proxy_index):
    if not account_id or str(account_id) == "0":
        return False

    user_ids = [int(account_id)]
    api_url = "https://presence.roblox.com/v1/presence/users"
    payload = {"userIds": user_ids}
    
    num_proxies = len(proxy_list)
    REQUIRED_VALID_CHECKS = 3
    valid_checks_count = 0
    current_idx = initial_proxy_index if initial_proxy_index >= 0 else 0
    consecutive_network_failures = 0
    MAX_CONSECUTIVE_FAILURES = 50 

    while valid_checks_count < REQUIRED_VALID_CHECKS:
        response = None
        while response is None:
            proxy = proxy_list[current_idx % num_proxies] if num_proxies > 0 else None
            proxy_info = f"Proxy #{current_idx % num_proxies + 1}" if num_proxies > 0 else "IP Gốc"
            
            ui_log("API", f"[{account_id}] Check {valid_checks_count + 1}/{REQUIRED_VALID_CHECKS} | {proxy_info}...")

            response = execute_api_request_simple('POST', api_url, json_data=payload, proxy=proxy)

            if response is None:
                consecutive_network_failures += 1
                ui_log("API", f"[{account_id}] Lỗi mạng -> Retry...")
                time.sleep(1)
                if num_proxies > 1:
                    current_idx += random.randint(1, num_proxies - 1)
                else: time.sleep(2)
                
                if consecutive_network_failures > MAX_CONSECUTIVE_FAILURES:
                    ui_log("API", f"[{account_id}] QUÁ NHIỀU LỖI. Hủy check.")
                    return False
            else:
                consecutive_network_failures = 0

        is_online = False
        if 'userPresences' in response:
            for p in response['userPresences']:
                # Điều kiện LITE: userPresenceType != 0 nghĩa là Online (Bao gồm Online, InGame, Studio)
                if p.get('userPresenceType') != 0 and str(p.get('userId')) == str(account_id):
                    is_online = True
        
        if is_online:
            ui_log("API", f"[{account_id}] ĐANG ONLINE! (Dừng check)")
            return True
        else:
            ui_log("API", f"[{account_id}] OFFLINE (OK {valid_checks_count + 1})")
            valid_checks_count += 1
            if num_proxies > 1:
                current_idx += random.randint(1, num_proxies - 1)
            time.sleep(0.5)

    ui_log("API", f"[{account_id}] XÁC NHẬN OFFLINE.")
    return False

def fetch_github_file(url):
    try:
        token = get_local_github_token()
        repo, path, branch = extract_github_info(url)
        if repo and path and token:
            api_url = f"https://api.github.com/repos/{repo}/contents/{path}?ref={branch}"
            headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github.v3.raw"}
            res = requests.get(api_url, headers=headers, timeout=10)
            if res.status_code == 200: return res.text
        else:
            res = requests.get(url, timeout=10)
            if res.status_code == 200: return res.text
    except Exception: pass
    return None

def update_github_file(url, new_content):
    token = get_local_github_token()
    repo, path, branch = extract_github_info(url)
    if not token or not repo or not path: return False
        
    api_url = f"https://api.github.com/repos/{repo}/contents/{path}"
    headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github.v3+json"}
    
    try:
        r = requests.get(api_url, headers=headers)
        if r.status_code != 200: return False
        sha = r.json().get("sha")
        
        encoded = base64.b64encode(new_content.encode('utf-8')).decode('utf-8')
        data = {"message": "Lychkins Lite: Sync Cookies", "content": encoded, "sha": sha, "branch": branch}
        res = requests.put(api_url, headers=headers, json=data)
        return res.status_code in [200, 201]
    except Exception: return False

