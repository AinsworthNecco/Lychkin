def initial_setup_and_claim(accounts, android_id):
    print_log("SETUP", "Tiến hành quét và xí chỗ Cookie (Dạng Raw, không mã hóa)...")
    data = fetch_github_file(COOKIE_URL)
    if not data:
        print_log("SETUP", "Lỗi tải danh sách Cookie!")
        return {}

    lines = data.splitlines()
    needed_suffixes = [acc['suffix'] for acc in accounts]
    owned_cookies_dict = {}
    unclaimed_cookies = []
    updated_lines = []
    changed = False
    now_str = datetime.now().strftime("%Y%m%d_%H%M%S")

    for raw_line in lines:
        line = raw_line.strip()
        if not line:
            updated_lines.append(line)
            continue

        # Dạng Raw không mã hóa. Cắt thẳng bằng Regex.
        m = re.search(r':([^:]+):(\d{8}_\d{6})$', line)
        if m:
            claimer_id = m.group(1)
            cookie_and_prefix = line[:m.start()]
        else:
            claimer_id = None
            cookie_and_prefix = line

        idx = cookie_and_prefix.find("_|WARNING:-DO-NOT-SHARE")
        if idx == -1:
            updated_lines.append(line)
            continue

        prefix = cookie_and_prefix[:idx]
        cookie_val = cookie_and_prefix[idx:]
        is_unclaimed = False

        if claimer_id and claimer_id.startswith(f"{android_id}-"):
            suffix_part = claimer_id[len(f"{android_id}-"):]
            if suffix_part in needed_suffixes and suffix_part not in owned_cookies_dict:
                owned_cookies_dict[suffix_part] = cookie_val
                updated_lines.append(line) # Giữ nguyên mộc mạc
            else:
                is_unclaimed = True
        elif claimer_id:
            # File test nên ta mặc định bỏ qua check thời gian 24h, cứ của máy khác là giữ nguyên
            updated_lines.append(line)
        else:
            is_unclaimed = True

        if is_unclaimed:
            unclaimed_cookies.append({'prefix': prefix, 'cookie_val': cookie_val, 'line': line})

    # Cấp phát cho các Tab còn thiếu
    missing_suffixes = [s for s in needed_suffixes if s not in owned_cookies_dict]
    for suffix in missing_suffixes:
        if unclaimed_cookies:
            item = unclaimed_cookies.pop(0)
            new_line = f"{item['prefix']}{item['cookie_val']}:{android_id}-{suffix}:{now_str}"
            updated_lines.append(new_line)
            owned_cookies_dict[suffix] = item['cookie_val']
            changed = True

    # Trả lại cookie thừa
    for item in unclaimed_cookies:
        clean_line = f"{item['prefix']}{item['cookie_val']}"
        updated_lines.append(clean_line)
        if item['line'] != clean_line: changed = True

    if changed:
        print_log("SETUP", "Phát hiện Cookie thay đổi, đang Push lên Github...")
        new_content = "\n".join(updated_lines)
        if update_github_file(COOKIE_URL, new_content):
            print_log("SETUP", "Push thành công!")

    # Bơm vào máy
    for acc in accounts:
        suffix = acc['suffix']
        assigned = owned_cookies_dict.get(suffix)
        if assigned:
            local = get_local_cookie(acc['pkg'])
            if local != assigned:
                print_log("INJECT", f"Đang bơm Cookie cho tab '{suffix}'...")
                inject_cookie_process(acc['pkg'], assigned)
            else:
                print_log("INJECT", f"Tab '{suffix}' đã khớp Cookie.")

    return owned_cookies_dict

def sync_cookies_to_github(accounts, android_id):
    """Moi Cookie dưới máy lên đè vào Github (Chỉ đè vào dòng của mình)."""
    print_log("SYNC", "Nhận lệnh YES! Tiến hành moi Cookie dưới máy đẩy lên mạng...")
    data = fetch_github_file(COOKIE_URL)
    if not data: return
    
    lines = data.splitlines()
    updated_lines = []
    now_str = datetime.now().strftime("%Y%m%d_%H%M%S")
    changed = False
    
    # Lấy toàn bộ cookie thực tế dưới máy
    local_cookies = {}
    for acc in accounts:
        local_val = get_local_cookie(acc['pkg'])
        if local_val: local_cookies[acc['suffix']] = local_val

    for line in lines:
        line = line.strip()
        m = re.search(r':([^:]+):(\d{8}_\d{6})$', line)
        if m:
            claimer_id = m.group(1)
            cookie_and_prefix = line[:m.start()]
            
            # Nếu dòng này thuộc về Tab của máy này
            if claimer_id.startswith(f"{android_id}-"):
                suffix = claimer_id[len(f"{android_id}-"):]
                if suffix in local_cookies:
                    prefix = cookie_and_prefix[:cookie_and_prefix.find("_|WARNING:-DO-NOT-SHARE")]
                    new_cookie_val = local_cookies[suffix]
                    
                    new_line = f"{prefix}{new_cookie_val}:{claimer_id}:{now_str}"
                    updated_lines.append(new_line)
                    if new_line != line: changed = True
                    continue
        
        # Nếu không phải của mình hoặc không match, giữ nguyên
        updated_lines.append(line)
        
    if changed:
        new_content = "\n".join(updated_lines)
        if update_github_file(COOKIE_URL, new_content):
            print_log("SYNC", "Đã cập nhật toàn bộ Cookie mới nhất lên Github thành công!")
        else:
            print_log("SYNC", "Lỗi: Không thể Push lên Github.")
    else:
        print_log("SYNC", "Cookie dưới máy không có gì mới so với trên Github. Bỏ qua push.")

def command_poller_loop(accounts, android_id):
    global last_command_state
    print_log("POLLER", "Bắt đầu luồng lắng nghe lệnh (15s/lần)...")
    while True:
        try:
            cmd_text = fetch_github_file(COMMAND_URL)
            if cmd_text:
                cmd_text = cmd_text.strip().lower()
                if cmd_text == "yes":
                    if last_command_state != "yes":
                        # Chỉ Sync khi chuyển từ trạng thái khác sang "yes" để tránh spam
                        sync_cookies_to_github(accounts, android_id)
                        last_command_state = "yes"
                else:
                    last_command_state = cmd_text
            time.sleep(15)
        except Exception as e:
            time.sleep(15)

def blind_launch_loop(accounts):
    print_log("LAUNCH", "Bắt đầu luồng Blind Launch (Mở app mù) mỗi 15s...")
    while True:
        for acc in accounts:
            pkg = acc['pkg']
            print_log("LAUNCH", f"Đang ra lệnh mở app: {pkg}")
            # Lệnh mở thẳng app ra màn hình chính, bỏ qua join game
            run_root_cmd(f"am start -n {pkg}/com.roblox.client.Activity")
            time.sleep(15)

