def find_real_cookie_path(package_name):
    base_path = f"/data/data/{package_name}/app_webview"
    # Bổ sung thêm các path của WebView đời mới (thường gặp trên giả lập/Android cao)
    possible_paths = [
        f"{base_path}/Default/Network/Cookies",
        f"{base_path}/Default/Cookies",
        f"{base_path}/Network/Cookies",
        f"{base_path}/Cookies"
    ]
    for path in possible_paths:
        out, _ = run_root_cmd(f"[ -f '{path}' ] && echo 'YES' || echo 'NO'")
        if "YES" in out: 
            return path
    return None

