def check_root_access():
    print("[MAIN] Đang kiểm tra quyền root...")
    try:
        process = subprocess.run(["su", "-c", "whoami"], capture_output=True, text=True, timeout=10)
        if process.stdout.strip() == "root":
            print("[MAIN] -> Quyền root: OK.")
            return True
