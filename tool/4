def get_roblox_user_id(cookie):
    url = "https://users.roblox.com/v1/users/authenticated"
    try:
        response = requests.get(url, cookies={'.ROBLOSECURITY': cookie}, timeout=10)
        if response.status_code == 200:
            return str(response.json().get('id'))
    except Exception: pass
    return None

def check_roblox_presence(account_id):
    if not account_id: return False
    url = "https://presence.roblox.com/v1/presence/users"
    payload = {"userIds": [int(account_id)]}
    try:
        response = requests.post(url, json=payload, timeout=10)
        if response.status_code == 200:
            data = response.json()
            if 'userPresences' in data:
                for p in data['userPresences']:
                    if p.get('userPresenceType') == 2 and str(p.get('userId')) == str(account_id):
                        return True
            return False
        else:
            return True # Tránh tắt nhầm khi API bị giới hạn (Rate limit)
    except Exception:
        return True # Tránh tắt nhầm khi rớt mạng tạm thời

