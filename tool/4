def build_config():
    """Tạo bộ cấu hình dùng chung tương thích với logic gốc"""
    config = {
        "BASE_PACKAGE_NAME": BASE_PACKAGE_NAME,
        "VIP_SERVER_URL": VIP_SERVER_URL,
        "LAUNCH_DELAY_SECONDS": LAUNCH_DELAY_SECONDS,
        "LAUNCH_INTERVAL_SECONDS": CHECK_INTERVAL_SECONDS,
        "CONNECTION_TIMEOUT": 15,
        "PROXY_LIST": PROXY_LIST
    }
    
    accounts = []
    local_ids = load_local_ids_from_file()
    suffixes = ACCOUNT_SUFFIXES.split()
    for i, s in enumerate(suffixes):
        s = s.strip()
        if s:
            uid = local_ids.get(s, "0")
            cookie = COOKIES[i] if i < len(COOKIES) else None
            accounts.append({'suffix': s, 'id': uid, 'cookie': cookie})
            
    config["ACCOUNT_SUFFIXES"] = accounts
    return config

def update_loop(config):
    """Vòng lặp duy trì việc kiểm tra Cookie định kỳ (mỗi 30 phút)"""
    thread_name = "UPDATE"
    while True:
        try:
            run_cookie_check_sequence(config, thread_name)
            countdown(1800, thread_name) # 30 phút
        except Exception as e:
            ui_log(thread_name, f"Lỗi Update Loop: {e}")
            time.sleep(60)

def launcher_loop(config):
    thread_name = "LAUNCH"
    ui_log(thread_name, f"Bắt đầu Launch Loop (VIP).")
    while True:
        launch_roblox_instances(config, thread_name)
        countdown(config.get("LAUNCH_INTERVAL_SECONDS", 60), thread_name)

