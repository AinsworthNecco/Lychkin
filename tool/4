def launch_roblox_instances(config, thread_name="LAUNCH"):
    accounts = config.get("ACCOUNT_SUFFIXES", [])
    base_pkg = config.get("BASE_PACKAGE_NAME", "com.roblox.client")
    formatted_proxies = format_proxies(config.get("PROXY_LIST", []))
    num_proxies = len(formatted_proxies)
    
    for i, acc in enumerate(accounts):
        suffix, uid = acc['suffix'], acc['id']
        pkg_name = f"{base_pkg}{suffix}"
        
        ui_log(thread_name, f"---- CHECK ACCOUNT: {suffix} (ID: {uid}) ----")
        
        is_process_active = check_process_running(pkg_name)
        should_launch = False
        
        if not is_process_active:
            ui_log(thread_name, f"App '{suffix}' đang TẮT -> START.")
            should_launch = True
        else:
            ui_log(thread_name, f"App '{suffix}' đang CHẠY -> Check API...")
            start_idx = random.randint(0, num_proxies - 1) if num_proxies > 0 else -1
            is_online = check_roblox_presence_single(uid, config, thread_name, formatted_proxies, start_idx)
            
            if is_online:
                ui_log(thread_name, f"'{suffix}' ONLINE -> Skip.")
                continue 
            else:
                ui_log(thread_name, f"'{suffix}' OFFLINE -> Kill & Restart.")
                try:
                    cmd_kill = f"PID=$(ps -ef | grep {pkg_name} | grep -v grep | awk '{{print $2}}'); if [ ! -z \"$PID\" ]; then kill -9 $PID; fi"
                    subprocess.run(["su", "-c", cmd_kill], capture_output=True, timeout=10)
                    time.sleep(3) 
                except: pass
                should_launch = True

        if should_launch:
            target_url = config.get('VIP_SERVER_URL', "")
            
            if target_url:
                cmd_launch = f"am start -a android.intent.action.VIEW -d '{target_url}' -p {pkg_name}"
                subprocess.run(["su", "-c", cmd_launch], capture_output=True)
                ui_log(thread_name, f"Đã start: {pkg_name}")
            
            delay = config.get("LAUNCH_DELAY_SECONDS", 10)
            if i < len(accounts) - 1:
                ui_log(thread_name, f"Đợi {delay}s...")
                time.sleep(delay)

