def check_root_access():
    try:
        process = subprocess.run(["su", "-c", "whoami"], capture_output=True, text=True, timeout=5)
        return "root" in process.stdout.strip()
    except Exception:
        return False

def run_root_cmd(command):
    try:
        full_cmd = f"su -c '{command}'"
        result = subprocess.run(full_cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        return result.stdout.strip(), result.stderr.strip(), result.returncode
    except Exception as e:
        return None, str(e), -1

def check_process_running(pkg_name):
    cmd = f"pidof {pkg_name}"
    out, _, _ = run_root_cmd(cmd)
    return bool(out.strip())

def force_stop_app(pkg_name):
    run_root_cmd(f"am force-stop {pkg_name}")

def launch_vip_server(pkg_name, url):
    cmd = f"am start -a android.intent.action.VIEW -d '{url}' -p {pkg_name}"
    run_root_cmd(cmd)

