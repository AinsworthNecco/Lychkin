#!/data/data/com.termux/files/usr/bin/python
# -*- coding: utf-8 -*-

import os
import sys
import time
import subprocess

# ==============================================================================
# CẤU HÌNH LITE (Sửa trực tiếp tại đây)
# ==============================================================================

BASE_PACKAGE_NAME = "com.roblox.client"             # Gói ứng dụng gốc
ACCOUNT_SUFFIXES = "2 3 4 5 6"              # Hậu tố app clone (cách nhau bởi dấu cách)
VIP_SERVER_URL = "https://www.roblox.com/share?code=98a1b858bf53db43b688552818e40748&type=Server" # Link VIP Server

LAUNCH_DELAY_SECONDS = 15     # Thời gian chờ (giây) giữa mỗi lần mở app clone
CHECK_INTERVAL_SECONDS = 300  # Thời gian chờ (giây) để vòng lặp quay lại kiểm tra từ đầu

# ==============================================================================
# CODE XỬ LÝ
# ==============================================================================

def check_root_access():
    """Kiểm tra quyền root của Termux"""
    try:
        process = subprocess.run(["su", "-c", "whoami"], capture_output=True, text=True, timeout=5)
        return "root" in process.stdout.strip()
    except Exception:
        return False

def launch_vip_server(pkg_name, url):
    """Gửi lệnh Intent mở app thẳng vào link VIP"""
    cmd = f"am start -a android.intent.action.VIEW -d '{url}' -p {pkg_name}"
    subprocess.run(["su", "-c", cmd], capture_output=True)

def main():
    os.system("termux-wake-lock") # Giữ cho Termux luôn chạy ngầm không bị ru ngủ
    
    print("=========================================")
    print("   LYCHKINS VIP AUTO JOIN (LITE VERSION) ")
    print("=========================================")
    
    if not check_root_access():
        print("[LỖI] Không có quyền Root! Vui lòng cấp quyền Root cho Termux.")
        sys.exit(1)

    suffixes = ACCOUNT_SUFFIXES.split()
    if not suffixes:
        print("[LỖI] Chưa điền ACCOUNT_SUFFIXES.")
        sys.exit(1)

    print(f"[*] Gói gốc: {BASE_PACKAGE_NAME}")
    print(f"[*] Số lượng Clone: {len(suffixes)}")
    print(f"[*] Link VIP: {VIP_SERVER_URL}\n")

    while True:
        print(f"\n[+] BẮT ĐẦU VÒNG LẶP AUTO JOIN: {time.strftime('%H:%M:%S')}")
        print("-" * 40)
        
        for suffix in suffixes:
            pkg_name = f"{BASE_PACKAGE_NAME}{suffix}"
            
            print(f"[>] Đang gửi lệnh join VIP Server cho app '{pkg_name}'...")
            launch_vip_server(pkg_name, VIP_SERVER_URL)
            
            print(f"    Đợi {LAUNCH_DELAY_SECONDS} giây...")
            time.sleep(LAUNCH_DELAY_SECONDS)
                
        print("-" * 40)
        print(f"[+] Hoàn tất 1 vòng. Nghỉ {CHECK_INTERVAL_SECONDS} giây trước khi chạy lại...")
        time.sleep(CHECK_INTERVAL_SECONDS)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n[!] Đã ép dừng script.")
        sys.exit(0)
