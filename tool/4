                else:
                    print(f"    -> OFFLINE. Đang ép tắt để chèn lại Cookie...")
                    force_stop_app(pkg_name)
                    time.sleep(3)
                    is_running = False # Chuyển sang bước Inject & Mở lại

            if not is_running:
                print(f"[>] {pkg_name} : Đang TẮT -> Inject Cookie & Join VIP...")
                success = inject_cookie_process(pkg_name, cookie)
