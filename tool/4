                ui_log(thread_name, f"Đang lấy ID mới cho '{suffix}'...")
                uid = get_roblox_user_id(assigned_cookie)
                if uid:
                    ui_log(thread_name, f"ID tìm thấy: {uid}")
                    update_local_config_file(suffix, uid)
                    acc['id'] = uid 
                else:
                    ui_log(thread_name, f"Không lấy được ID từ API.")
    ui_log(thread_name, "Hoàn tất kiểm tra cookie.")

