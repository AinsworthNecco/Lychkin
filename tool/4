                    continue
            
            uid = ACCOUNT_DATA[pkg_name]
            is_running = check_process_running(pkg_name)

            # 2. Xử lý logic check App & API
            if is_running:
                print(f"[?] {pkg_name} : Đang CHẠY -> Check API Presence (ID: {uid})...")
