#!/data/data/com.termux/files/usr/bin/bash

# ==========================================
# CẤU HÌNH CƠ BẢN
# ==========================================
CHECK_INTERVAL=120           # Quét trạng thái App mỗi 2 phút (120 giây)
RESTART_INTERVAL=21600       # Force stop và mở lại toàn bộ sau 6 tiếng (21600 giây)
ENABLE_AUTO_RESTART="ON"      # Công tắc: "ON" để bật, "OFF" để tắt tự động Restart
ENABLE_HARDCORE_OPTIMIZE="ON" # Bật tối ưu hóa sâu (Giảm sáng, dọn RAM, chống kill ngầm)

# ==========================================
# CẤU HÌNH EXTREME (VẮT KIỆT MÁY CŨ)
# ==========================================
ENABLE_EXTREME_MODE="ON"      # Bật ép Swap RAM và Giảm FPS (Cảnh báo: Hại bộ nhớ máy)
SWAP_SIZE_MB=12288            # Dung lượng Swap RAM ảo tạo thêm (12GB)
TARGET_FPS=30.0               # Ép tần số quét/FPS thấp nhất có thể (30 hoặc 60)

JOIN_TARGET="https://www.roblox.com/share?code=98a1b858bf53db43b688552818e40748&type=Server"
BASE_PACKAGE_NAME="com.roblox.clien"  
ACCOUNT_SUFFIXES="b c d e f"          

# ==========================================
# CÁC HÀM XỬ LÝ & TỐI ƯU
# ==========================================

setup_environment() {
    echo "[SETUP] Đang thiết lập môi trường và tối ưu hóa hệ thống..."
    
    # 1. Thiết lập màn hình hiển thị
    su -c "wm size 1280x2800"
    su -c "wm density 350"
    su -c "settings put system accelerometer_rotation 0"
    su -c "settings put system user_rotation 1" # Xoay ngang
    
    # 2. Tắt hoàn toàn Animation (Hoạt ảnh) để giảm tải GPU/CPU
    su -c "settings put global window_animation_scale 0"
    su -c "settings put global transition_animation_scale 0"
    su -c "settings put global animator_duration_scale 0"
    
    # 3. Kích hoạt tính năng Đa cửa sổ (Multi-window / Freeform)
    su -c "settings put global force_resizable_activities 1"
    su -c "settings put global enable_freeform_support 1"
    su -c "settings put global force_allow_on_external 1"
    
    if [ "$ENABLE_HARDCORE_OPTIMIZE" == "ON" ]; then
        # 4. Vô hiệu hóa Phantom Process (Chống Android 12+ kill Termux/Clone ngầm)
        su -c "device_config put activity_manager max_phantom_processes 2147483647 >/dev/null 2>&1"
        su -c "settings put global settings_enable_monitor_phantom_procs false >/dev/null 2>&1"
        
        # 5. Tối ưu nhiệt độ & Pin khi treo
        su -c "settings put system screen_brightness_mode 0" # Tắt độ sáng tự động
        su -c "settings put system screen_brightness 1"      # Giảm độ sáng xuống thấp nhất
        su -c "settings put global stay_on_while_plugged_in 7" # Luôn thức khi cắm sạc
        su -c "dumpsys deviceidle disable >/dev/null 2>&1"     # Tắt Doze Mode chống rớt mạng
        
        echo "[SETUP] Đã bật chế độ Tối ưu hóa sâu (Hardcore Optimize)."
    fi

    if [ "$ENABLE_EXTREME_MODE" == "ON" ]; then
        echo "[EXTREME] Bắt đầu kích hoạt các tinh chỉnh vắt kiệt phần cứng..."
        
        # 6. Ép giảm FPS (Giảm tần số quét màn hình, giảm tải GPU)
        su -c "settings put system min_refresh_rate $TARGET_FPS"
        su -c "settings put system peak_refresh_rate $TARGET_FPS"
        su -c "setprop debug.hwui.fps_divisor 2 >/dev/null 2>&1" # Giảm nửa FPS dựng hình giao diện
        
        # 7. Thiết lập Swap RAM ảo trên bộ nhớ trong
        echo "  -> Đang thiết lập $SWAP_SIZE_MB MB Swap RAM..."
        su -c "if [ ! -f /data/swapfile ]; then 
            dd if=/dev/zero of=/data/swapfile bs=1M count=$SWAP_SIZE_MB; 
            mkswap /data/swapfile; 
            chmod 600 /data/swapfile; 
        fi"
        su -c "swapon /data/swapfile >/dev/null 2>&1"
        
        # 8. Tinh chỉnh Kernel để bào Swap RAM và giữ RAM thực tế
        su -c "echo 100 > /proc/sys/vm/swappiness"            # Ép dùng Swap tối đa (Mặc định 60)
        su -c "echo 10 > /proc/sys/vm/watermark_scale_factor" # Dọn RAM sớm hơn bình thường
        su -c "echo 100 > /proc/sys/vm/vfs_cache_pressure"    # Xóa cache file hệ thống nhanh hơn
        
        echo "[EXTREME] Kích hoạt Swap RAM và Giới hạn FPS thành công!"
    fi

    sleep 2
    echo "[SETUP] Hoàn tất thiết lập môi trường!"
    echo ""
}

is_running() {
    local pkg=$1
    local output=$(su -c "ps -ef | grep $pkg | grep -v grep")
    if [[ -n "$output" ]]; then
        return 0 # Đang chạy
    else
        return 1 # Đã tắt
    fi
}

launch_app() {
    local pkg=$1
    local deeplink="$JOIN_TARGET"
    if [[ "$deeplink" =~ ^[0-9]+$ ]]; then
        deeplink="roblox://placeId=${deeplink}"
    fi
    # Bật chế độ cửa sổ (5)
    su -c "am start --windowingMode 5 -a android.intent.action.VIEW -d '${deeplink}' -p ${pkg} > /dev/null 2>&1"
}

kill_all_roblox() {
    echo "[RESTART] Đã đủ thời gian, đang tiến hành đóng toàn bộ Roblox..."
    for suffix in $ACCOUNT_SUFFIXES; do
        pkg="${BASE_PACKAGE_NAME}${suffix}"
        su -c "am force-stop $pkg"
        echo "  -> Đã đóng $pkg"
    done
    
    # [TỐI ƯU THÊM] Dọn dẹp RAM (Drop Caches & Swap) sau khi kill app để giải phóng bộ nhớ
    if [ "$ENABLE_HARDCORE_OPTIMIZE" == "ON" ]; then
        echo "  -> [OPTIMIZE] Đang dọn dẹp Cache và RAM hệ thống..."
        su -c "sync && echo 3 > /proc/sys/vm/drop_caches"
        
        # Nếu bật Extreme, ta cũng nên dọn Swap 1 lần trong ngày để tránh phân mảnh quá nặng
        if [ "$ENABLE_EXTREME_MODE" == "ON" ]; then
            # Chỉ dọn swap 1 cách an toàn: tắt đi bật lại
            echo "  -> [EXTREME] Đang làm mới Swap RAM (Có thể mất thời gian)..."
            su -c "swapoff /data/swapfile && swapon /data/swapfile" >/dev/null 2>&1
        fi
    fi
    
    sleep 3
    echo "[RESTART] Đã đóng và dọn dẹp xong. Vòng lặp Monitor sẽ tự mở lại app."
}

# ==========================================
# CÁC VÒNG LẶP ĐỘC LẬP
# ==========================================

# Vòng lặp 1: Kiểm tra và mở lại App
loop_app_monitor() {
    while true; do
        H_TIME=$(date +"%H:%M:%S")
        echo "[$H_TIME] Đang kiểm tra trạng thái các App..."
        for suffix in $ACCOUNT_SUFFIXES; do
            pkg="${BASE_PACKAGE_NAME}${suffix}"
            
            if is_running "$pkg"; then
                echo "  [OK] $pkg đang chạy."
            else
                echo "  [START] $pkg đã tắt -> Đang mở lại..."
                launch_app "$pkg"
                sleep 5 # Đợi một chút để app load rồi mới mở app tiếp theo
            fi
        done
        sleep $CHECK_INTERVAL
    done
}

# Vòng lặp 2: Tự động khởi động lại toàn bộ
loop_auto_restart() {
    while true; do
        sleep $RESTART_INTERVAL
        kill_all_roblox
    done
}

# ==========================================
# CHƯƠNG TRÌNH CHÍNH
# ==========================================

# Khôi phục độ sáng màn hình và FPS khi dừng script (Ctrl+C)
cleanup_on_exit() {
    echo -e '\n[!] Đang đóng tiến trình và khôi phục hệ thống...'
    su -c 'settings put system screen_brightness 100'
    if [ "$ENABLE_EXTREME_MODE" == "ON" ]; then
        su -c "settings put system peak_refresh_rate 60.0"
        su -c "settings put system min_refresh_rate 60.0"
        su -c "setprop debug.hwui.fps_divisor 1 >/dev/null 2>&1"
        su -c "swapoff /data/swapfile >/dev/null 2>&1"
    fi
    kill 0
    exit
}

trap cleanup_on_exit SIGINT SIGTERM

termux-wake-lock

echo "======================================="
echo "  AUTO RESTARTER PRO V3 (EXTREME)      "
echo "  Chế độ vắt kiệt: SWAP RAM & GIẢM FPS "
echo "======================================="
echo ""

# Setup môi trường
setup_environment

echo "[MAIN] Khởi chạy các vòng lặp ngầm..."

# Gọi chạy ngầm bằng toán tử '&'
loop_app_monitor &

# Bật/Tắt vòng lặp Restart tùy theo công tắc
if [ "$ENABLE_AUTO_RESTART" == "ON" ]; then
    echo "  -> Chức năng Auto Restart (6 tiếng): ĐANG BẬT"
    loop_auto_restart &
else
    echo "  -> Chức năng Auto Restart: ĐÃ TẮT"
fi

# Dùng wait để giữ script chính sống
wait
