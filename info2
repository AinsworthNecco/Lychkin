# ==========================================
# CH∆Į∆†NG TR√ĆNH CH√ćNH (V√íNG LŠļ∂P UI)
# ==========================================

cleanup_on_exit() {
    tput cnorm 2>/dev/null || true # HiŠĽán lŠļ°i con trŠĽŹ chuŠĽôt khi tho√°t
    clear
    echo -e '\n[!] ńźang ńĎ√≥ng tiŠļŅn tr√¨nh v√† kh√īi phŠĽ•c hŠĽá thŠĽĎng...'
    su -c 'settings put system screen_brightness 100'
    if [ "$ENABLE_EXTREME_MODE" == "ON" ]; then
        su -c "settings put system peak_refresh_rate 60.0"
        su -c "settings put system min_refresh_rate 60.0"
        su -c "setprop debug.hwui.fps_divisor 1 >/dev/null 2>&1"
        su -c "swapoff /data/swapfile >/dev/null 2>&1"
    fi
    echo -e '\e[0m'
    kill 0
    exit
}

trap cleanup_on_exit SIGINT SIGTERM

termux-wake-lock
setup_environment

# Main Loop (1 Gi√Ęy / LŠļßn)
while true; do
    get_cpu
    get_ram
    draw_ui

    if [ "$ENABLE_AUTO_RESTART" == "ON" ] && [ $RESTART_TIMER -le 0 ]; then
        do_restart
        RESTART_TIMER=$RESTART_INTERVAL
    fi

    if [ $CHECK_TIMER -le 0 ]; then
        for suffix in $ACCOUNT_SUFFIXES; do
            pkg="${BASE_PACKAGE_NAME}${suffix}"
            if is_running "$pkg"; then
                APP_STATUS["$pkg"]="Running"
            else
                APP_STATUS["$pkg"]="Starting"
                draw_ui # Update UI ngay lŠļ≠p tŠĽ©c ńĎŠĽÉ User thŠļ•y n√≥ ńĎang "Starting"
                launch_app "$pkg"
                sleep 5
                # TrŠĽę b√Ļ thŠĽĚi gian bŠĽč delay do lŠĽánh sleep
                ((CHECK_TIMER-=5))
                ((RESTART_TIMER-=5))
            fi
        done
        CHECK_TIMER=$CHECK_INTERVAL
    fi

    sleep 1
    ((CHECK_TIMER--))
    ((RESTART_TIMER--))
done
